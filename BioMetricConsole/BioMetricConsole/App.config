<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.6.1"/>
    </startup>

  <appSettings>
    <add key="OfficeId" value="2"/>

  </appSettings>
 
  
  <system.serviceModel>
    <bindings>
      <basicHttpBinding>
        <binding name="LogPushSoap" />
      </basicHttpBinding>
    </bindings>
    <client>
      <endpoint address="http://localhost:51947/LogPush.asmx" binding="basicHttpBinding"
        bindingConfiguration="LogPushSoap" contract="AttendanceLogRefrence.LogPushSoap"
        name="LogPushSoap" />
    </client>
  </system.serviceModel>
</configuration>

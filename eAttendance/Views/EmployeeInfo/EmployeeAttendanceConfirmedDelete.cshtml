@model eAttendance.Models.EmployeeAttendanceLogModel
@{
    Layout = "~/Views/Shared/_Blank.cshtml";
}
<div class="modal-dialog">
    <div class="modal-content">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">×</span><span class="sr-only">Close</span></button>
            <h4 class="modal-title"><i class="fa fa-question-circle fa-2x"></i></h4>
            <small class="font-bold"></small>
        </div>
        @using (Html.BeginForm("DeleteEmployeeAttendanceConfirmed", "EmployeeInfo", FormMethod.Post, new { @class = "form-horizontal" }))
        {
            <div class="modal-body">
                @Html.HiddenFor(m=> m.DeviceDataId)
                @Html.HiddenFor(m=>m.ForegotEntryId)
                @Html.HiddenFor(m=>m.nLogDate)
                @Html.HiddenFor(m=>m.OfficeId)
                @Html.HiddenFor(m => m.EmployeeId)
                @Html.HiddenFor(m=> m.BranchId)
                @Html.HiddenFor(m=> m.ServiceId)
                @Html.HiddenFor(m=>m.LevelId)
                @Html.HiddenFor(m=>m.DesignationId)
                @Html.HiddenFor(m=> m.EmployeeId)
                @Html.HiddenFor(m => m.Status)
                <div class="form-group">
                    <label class="col-sm-3 control-label">@Html.DisplayNameFor(m => m.Remarks)</label>
                    <div class="col-sm-9">
                        @Html.TextAreaFor(m => m.Remarks, new { @class = "form-control",@style="min-height:100px;" })
                    </div>
                </div>
                <div class="form-group">
                    <div class="col-sm-offset-3 col-sm-9">
                        <h3>तपाईं मेटाउन निश्चित हुनुहुन्छ ?</h3>
                        </div>
                </div>
                
                
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary btn-sm">हो </button>
                <button type="button" class="btn btn-danger btn-sm" data-dismiss="modal">होइन</button>
            </div>
        }
    </div>
</div>



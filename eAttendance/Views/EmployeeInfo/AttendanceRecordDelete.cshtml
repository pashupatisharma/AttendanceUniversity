@using eAttendance.Models
@model eAttendance.Models.EmployeeAttendanceLogModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Employee Information";
}
<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-lg-8">
        <h2>कर्मचारी को हाजिरी मेटाउने</h2>
     
    </div>
    
</div>
<div class="wrapper wrapper-content padding-top-md">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox float-e-margins no-margins">
                <div class="ibox-content no-border-bottom">
                    @using (Html.BeginForm("AttendanceRecordDelete", "EmployeeInfo", FormMethod.Get, new { @class = "form-view-data", @id = "frmEmployeeAttendance" }))
                    {
                    <fieldset>
                        <legend>Search Criteria</legend>
                        <div class="row">
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="control-label">मिति</label>
                                    @Html.TextBox("nLogDate", "", new { @class = "form-control inputmask nepali-calendar", data_mask = "9999-99-99" })
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="control-label">कार्यालय</label>
                                    @Html.DropDownList("officeId", eAttendance.Utility.GetOfficeIdNameWithSelect(User), "छान्नुहोस्", new { @class = "chosen-select form-control chosen-select", @required = "required" })
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="control-label">शाखा</label>
                                    @Html.DropDownList("branchId", Utility.GetBranchIdName(User), new { @class = "chosen-select form-control chosen-select" })
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="control-label ">सेवा</label>
                                    @Html.DropDownList("serviceId", eAttendance.Utility.GetServiceIdName(User), new { @class = "chosen-select form-control chosen-select" })
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="control-label">तह</label>
                                    @Html.DropDownList("levelId", eAttendance.Utility.GetLevelIdName(), new { @class = "chosen-select form-control chosen-select" })
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="control-label">पद</label>
                                    @Html.DropDownList("designationId", eAttendance.Utility.GetDesignationIdName(User), new { @class = "chosen-select form-control chosen-select" })
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="control-label">कर्मचारी</label>
                                    @Html.DropDownList("empId", Enumerable.Empty<SelectListItem>(), "Select", new { @class = "chosen-select form-control chosen-select" })






                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="control-label">@eAttendance.Service.MenuService.Status</label>
                                    @Html.DropDownList("statusId", eAttendance.Utility.GetStatus(), new { @class = "chosen-select form-control chosen-select" })
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group margin-top-25">
                                    <button type="submit" class="btn-Search btn btn-primary btn-rounded btn-outline fa fa-search"> खोज्नुहोस्</button>
                                </div>
                            </div>
                        </div>
                    </fieldset>
                    }
                </div>
            </div>
            <div class="ibox">
                <div class="ibox-content no-padding no-margins">
                    <div class="project-list">
                        @if (Model.EmployeeAttendanceLogModelList != null)
                        {
                            <table id="tblAttencdanceRecord" class="table table-hover table-condensed table-striped">
                                <thead>
                                    <tr>
                                        <th>क्र सं</th>
                                        <th class="col-md-2">पद</th>
                                        <th>कर्मचारी</th>
                                        <th>@eAttendance.Service.MenuService.Date</th>
                                        <th>@eAttendance.Service.MenuService.Time</th>
                                        <th class="hidden-print col-md-2"></th>
                                    </tr>

                                </thead>
                                <tbody>
                                    @{int count = 0;
                                    ApplicationDbContext atn = new ApplicationDbContext();}
                                    @foreach (var m in Model.EmployeeAttendanceLogModelList)
                                    {
                                        count += 1;
                                        var office = atn.EmployeeOfficeDetail.Where(x => x.EmployeeId == m.EmployeeId).FirstOrDefault();
                                        <tr>
                                            <td>@count</td>
                                            <td class="col-md-2">
                                                @{
                                        if (office != null && office.DesignationSetUp != null)
                                        {
                                            @Html.Raw(office.DesignationSetUp.DesignationName)
                                        }
                                                }
                                            </td>

                                            <td class="project-title">

                                                @m.EmployeeNameNp [@m.EmployeeNo]
                                                <br />
                                                @if (office != null)
                                                {
                                                    @Html.Raw(office.OfficeSetUp.OfficeName)
                                                }
                                            </td>
                                            <td>@((m.DateTime.Value.Year >= 1913 && m.DateTime.Value.Year <= 2042) ? eAttendance.NepaliDateConverter.ConvertToNepali(m.DateTime.Value.Date) : NepaliDateConverter.ConvertToNepali(DateTime.Today.Date))</td>
                                            <td>@m.DateTime.Value.ToShortTimeString()</td>

                                            <td class="hidden-print project-actions col-md-2">
                                                @if (m.Status != null && (m.Status == 1 || m.Status == 4))
                                                {
                                                    if (User.IsInRole("SuperAdmin") || User.IsInRole("Administrator") || User.IsInRole("Admin"))
                                                    {
                                                        var a = m.DeviceDataId + "," + m.ForegotEntryId;
                                                        <button value="@a" type="button" class="btn-delete btn btn-danger btn-sm"><i class="fa fa-remove"></i> <span class="hidden-xs hidden-sm"></span> </button>
                                                    }
                                                }
                                            </td>
                                        </tr>
                                    }
                                    @if (count == 0)
                                    {
                                        <tr>
                                            <td class="text-center alert-info" colspan="9">
                                                <strong> @eAttendance.Service.MenuService.NoRecordFound </strong>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <div class="modal inmodal fade" id="modelDelete" role="dialog">

    </div>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.nepali-calendar').nepaliDatePicker();
            $(".chosen").chosen({ width: '100%', disable_search_threshold: 10 });
            $(".chosen-select").chosen({ width: '100%' });
            $.validator.setDefaults({ ignore: ":hidden:not(select)" });
            $("#frmEmployeeAttendance").validate({
                rules: {
                    "nLogDate": { required: true },
                    "officeId": {
                        min: 1
                    },
                    "empId": { min: 1 },
                    "statusId": { min: 1 }
                },
                messages:
                {
                    "nLogDate": { required: 'कृपया विकल्प चयन गर्नुहोस्' },
                    "officeId": {
                        min: 'कृपया विकल्प चयन गर्नुहोस्'
                    },
                    "empId": { min: 'कृपया विकल्प चयन गर्नुहोस्' },
                    "statusId": { min: 'कृपया विकल्प चयन गर्नुहोस्' }

                }
            });
            $('#officeId').chosen().change(function () {

                var officeId = $(this).val();



                $.ajax({
                    type: "POST",
                    url: '@Url.Action("GetEmployeeBy", "Utility")',
                    data: {
                        OfficeId: officeId,
                        BranchId: 0,
                        LevelId: 0,
                        DesignationId: 0,
                        ServiceId: 0,
                        withAll: true,
                        withSelect: false
                    },

                    cache: false,
                    success: function (data) {
                        $("#empId").empty();
                        var $prevGroup, prevGroupName;
                        $.each(data,
                            function () {
                                if (this.Group == null) {
                                    $("<option />").val(this.Value).text(this.Text).appendTo('#empId');
                                } else {
                                    if (prevGroupName != this.Group.Name) {
                                        $prevGroup =
                                            $('<optgroup />').prop('label', this.Group.Name).appendTo('#empId');
                                    }
                                    $("<option />").val(this.Value).text(this.Text).appendTo($prevGroup);
                                    prevGroupName = this.Group.Name;
                                }
                            });
                        $("#empId").trigger('chosen:updated');
                    },
                    error: function () {
                        alert("Failed to load Item");
                    }
                });

            });



            $("#levelId").chosen().change(function () {
                // Loading Designation
                var officeId = $("#officeId").val();
                var levelId = $(this).val();
                $.getJSON("@Url.Action("GetDesignationByOfficeId", "Report")", { OfficeId: officeId, LevelId: levelId },
                 function (data) {
                     $("#designationId").empty();
                     var $prevGroup, prevGroupName;
                     $.each(data, function () {
                         if (this.Group == null) { $("<option />").val(this.Value).text(this.Text).appendTo('#designationId'); }
                         else {
                             if (prevGroupName != this.Group.Name) { $prevGroup = $('<optgroup />').prop('label', this.Group.Name).appendTo('#designationId'); }
                             $("<option />").val(this.Value).text(this.Text).appendTo($prevGroup);
                             prevGroupName = this.Group.Name;
                         }
                     });
                     $("#designationId").trigger('chosen:updated');
                 });
            });

            toastr.options = {
                "progressBar": true,
                "positionClass": "toast-top-center",
                "preventDuplicates": false,
                "showDuration": "300",
                "hideDuration": "1000",
                "timeOut": "5000",
                "extendedTimeOut": "1000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut"
            }
            var hasMessage = '@TempData["HasMessage"]';
            if (hasMessage) {
                Command: toastr["@TempData["MessageType"]"]("@TempData["Message"]", "@TempData["MessageHeader"]")
            }
            //Changes for deletion
            $('.btn-delete').on('click', function () {
                var Ids = $(this).attr('value');
              
                var NLogDate = $("#nLogDate").val();
                var OfficeId = $("#officeId").val();
                var BranchId = $("#branchId").val();
                var ServiceId = $("#serviceId").val();
                var LevelId = $('#levelId').val();
                var DesignationId = $("#designationId").val();
                var EmployeeId = $("#empId").val();
                var StatusId = $("#statusId").val();
                $.ajax({
                    url: '@Url.Action("EmployeeAttendanceConfirmedDelete", "EmployeeInfo")',
                    
                    type: 'GET',
                    data: {
                        value: Ids,
                        nLogDate: NLogDate,
                        officeId: OfficeId,
                        branchId: BranchId,
                        serviceId: ServiceId,
                        levelId: LevelId,
                        designationid: DesignationId,
                        employeeId: EmployeeId,
                        statusId: StatusId
                    },
                    success: function (result) {
                        console.log(result)
                        $("#modelDelete").html(result);
                        $("#modelDelete").modal('show');
                    },
                    error: function () {
                    }
                });
            })
        })
    </script>
}

@model eAttendance.Models.SetupShiftTime
@{
    Layout = "~/Views/Shared/_Blank.cshtml";
}
<div class="modal-dialog">
    <div class="modal-content">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">×</span><span class="sr-only">Close</span></button>
            <h4 class="modal-title">मेटाउन सिफ्ट टाईम</h4>
            <small class="font-bold"></small>
        </div>
        @using (Html.BeginForm("Delete", "SetupShiftTime", FormMethod.Post, new { @class = "form-horizontal" }))
        {
            <div class="modal-body">
                @Html.HiddenFor(m => m.ShiftId)
                @Html.HiddenFor(m => m.OfficeId)
                @Html.HiddenFor(m => m.ShiftName)
                @Html.HiddenFor(m => m.Alias)
                @Html.HiddenFor(m => m.Description)
                @Html.HiddenFor(m => m.ShiftStartTime)
                @Html.HiddenFor(m => m.ShiftEndTime)
                @Html.HiddenFor(m => m.ShiftHours)
                @Html.HiddenFor(m => m.ShiftLateInAfter)
                @Html.HiddenFor(m => m.ShiftEarlyOutBefore)
                @Html.HiddenFor(m => m.BreakStartTime)
                @Html.HiddenFor(m => m.BreakEndTime)
                @Html.HiddenFor(m => m.BreakDuration)
                @Html.HiddenFor(m => m.BreakLateInAfter)
                @Html.HiddenFor(m => m.BreakEarlyOutBefore)
                @Html.HiddenFor(m => m.OverTimeBefore)
                @Html.HiddenFor(m => m.OverTimeAfter)
                @Html.HiddenFor(m => m.DisplayOrder)
                @Html.HiddenFor(m => m.IsDefault)
                @Html.HiddenFor(m => m.CreatedBy)
                @Html.HiddenFor(m => m.CreatedDate)
                <p><i class="fa fa-question-circle"></i>तपाईं मेटाउन निश्चित हुनुहुन्छ?</p>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary btn-sm">हो </button>
                <button type="button" class="btn btn-danger btn-sm" data-dismiss="modal">होइन</button>
            </div>
        }
    </div>
</div>



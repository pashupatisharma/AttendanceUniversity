            $('#tblDistrict tbody').on('click', '.btn-delete', function () {
            var districtId = $(this).attr('value');
            $.ajax({
                url: '@Url.Action("Delete", "SetupDistrict")',
                type: 'GET',
                data: { id: districtId },
                success: function (result) {
                    console.log(result)
                    $("#modelDelete").html(result);
                    $("#modelDelete").modal('show');
                },
                error: function () {

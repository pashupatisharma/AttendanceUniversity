@model eAttendance.Models.DistrictSetUp
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Setup District";
}
<div class="modal-content">
    <div class="modal-header">
        <ol class="breadcrumb">
            <li class="animated fadeInUp">सेटअप</li>
            <li class="animated fadeInLeft"><a href="@Url.Action("Index","SetupDistrict")">जिल्ला सेटअप</a></li>
            <li class="animated fadeInRight">जिल्लाका सूचीहरु</li>

        </ol>
    </div>
</div>

<div class="row wrapper white-bg page-heading hidden-print">
    <div class="col-lg-10">
        <h2>जिल्ला सेटअप </h2>

    </div>
    <div class="col-lg-2">
        <div class="title-action hidden-print">
            <button class="btn btn-primary btn-sm btn-add" onclick="location.href='@Url.Action("Add","SetupDistrict")'">नयाँ बनाउनु </button>
        </div>
    </div>
</div>
<div class="col-lg-12">
    <div class="card">
        <div class="card-header bg-info">
            <h2 class="m-b-0 text-info">जिल्ला सेटअप  </h2>
        </div>
        <div class="card-body">
            <table id="tblDistrict" class="table table-hover table-condensed table-color ">
                <thead>
                    <tr>
                        <th>क्र सं</th>
                        <th>@Html.DisplayNameFor(m => m.DistrictName)</th>
                        <th>@Html.DisplayNameFor(m => m.DistrictCode)</th>
                        <th>@Html.DisplayNameFor(m => m.ZoneId)</th>
                        <th class="hidden-print">कार्य </th>
                    </tr>

                </thead>
                <tbody>
                    @{ int count = 0;}
                    
                    @foreach (var m in Model.SetupDistrictList)
                    {
                        count += 1;
                        <tr>
                            <td>@count</td>
                            <td class="project-title">
                                <a href="">@m.DistrictName</a>
                            </td>
                            <td>@m.DistrictCode</td>
                            <td>@Utility.GetZoneName(m.ZoneId)</td>
                            <td class="project-actions hidden-print">
                                <button value="@m.DistrictId" type="button" class="btn-edit btn btn-primary btn-sm" onclick="location.href='@Url.Action("Edit","SetupDistrict",new { @id=m.DistrictId})'"><i class="fa fa-pencil"></i> <span class="hidden-xs hidden-sm"></span> </button>
                                <button value="@m.DistrictId" class="btn-delete btn btn-sm btn-danger"><i class="fa fa-remove"></i><span class="hidden-xs hidden-sm"></span> </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal inmodal fade" id="modelDelete" role="dialog">

</div>


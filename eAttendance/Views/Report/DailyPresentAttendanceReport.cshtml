@model  eAttendance.ReportModel.EmployeeAttendanceList

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Daily Presence Attendance Report";
}
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
<script src="~/Scripts/ExcelExport.js"></script>
<div id="divLoading" style="margin: 0px; padding: 0px; position: fixed; right: 0px;
                                      top: 0px; width: 100%; height: 100%; background-color: #666666; z-index: 30001;
                                      opacity: .8; filter: alpha(opacity=70); display: none">
    <p style="position: absolute; top: 30%; left: 45%; color: White; text-align: center;">
        <img src="~/Images/ajax-loading.gif" />
        <br />
        Loading Please Wait...........
    </p>
</div>

<script>

    function ShowLoader() {
        $("#divLoading").show();
    }
    function EndLoader() {
        $("#divLoading").hide();
    }
</script>
<style>
    hr {
        margin-top: 0px;
        margin-bottom: 0px;
        border: 0;
        border-top: 1px solid #eee;
    }
</style>
<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-lg-8 col-md-8 col-sm-8">
        <h2>@eAttendance.Service.MenuService.DailyPresentAttendanceReport</h2>
        <ol class="breadcrumb">
            <li><a href="@Url.Action("Index","Home")">घर</a></li>
            <li>@eAttendance.Service.MenuService.Report</li>
            <li class="active"><strong>@eAttendance.Service.MenuService.DailyPresentAttendanceReport</strong></li>
        </ol>
    </div>
    <div class="col-lg-4 col-md-4 col-sm-4">
        <div class="title-action">
            
            <a download="Daily Report.xls" class="btn btn-success btn_excel fa fa-file-excel-o" href="#" onclick="return ExcellentExport.excel(this, 'divprint', 'Daily Report');">Excel मा लैजानुहोस् </a>



             <button id="btnPrint" type="button" class="btn btn-primary btn-sm"><i class="fa fa-print"></i> Print </button>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-lg-12">
        <div class="wrapper wrapper-content animated fadeInDown no-margins padding-top-md">
            <div class="ibox float-e-margins no-margins">
                <div class="ibox-title">
                    <h5><i class="fa fa-filter"></i> @eAttendance.Service.MenuService.Filter  </h5>
                    <div class="ibox-tools">
                        <a class="collapse-link">
                            <i class="fa fa-chevron-up"></i>
                        </a>
                    </div>
                </div>
                <div class="ibox-content no-border-bottom">
                    
                        @using (Ajax.BeginForm("DailyPresentAttendanceReport", "Report", new AjaxOptions { HttpMethod = "Post", OnBegin = "ShowLoader", OnComplete = "EndLoader", UpdateTargetId = "divprint" }))
                         {


                        <div class="row">
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="control-label">@eAttendance.Service.MenuService.Date</label>
                                    @Html.TextBoxFor(m => m.nLogDate, "{0:yyyy/MM/dd }", new { @class = "form-control inputmask nepali-calendar", @mask = "9999-99-99" })
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="control-label">कार्यालय</label>
                                    @Html.DropDownListFor(m => m.OfficeId, Utility.GetOfficeIdNameWithSelect(User), new { @class = "chosen-select form-control" })
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="control-label">शाखा</label>

                                    @Html.DropDownListFor(m => m.BranchId, Utility.GetBranchIdName(@User), new { @class = "chosen-select form-control" })
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="control-label ">सेवा</label>
                                    @Html.DropDownListFor(m => m.ServiceId, Utility.GetServiceIdName(), new { @class = "chosen-select form-control" })
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="control-label">तह</label>
                                    @Html.DropDownListFor(m => m.LevelId, Utility.GetLevelIdName(), new { @class = "chosen-select form-control" })
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="control-label">पद</label>
                                    @Html.DropDownListFor(m => m.DesignationId, Enumerable.Empty<SelectListItem>(), new { @class = "chosen-select form-control" })
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group">
                                    <label class="control-label">कर्मचारी र @eAttendance.Service.MenuService.EmployeeNo</label>
                                    @Html.DropDownListFor(m => m.EmployeeId, Enumerable.Empty<SelectListItem>(), new { @class = "chosen-select form-control chosen-select" })
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <div class="form-group margin-top-25">
                                    <button type="submit" class="btn-Search btn btn-primary btn-rounded btn-outline fa fa-search"> खोज्नुहोस्</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="ibox float-e-margins mt-15 padding-top-xs">
                <div class="ibox-title">
                    <h5>उपस्थित</h5>
                </div>
                <div id="divprint" class="ibox-content p-xl no-padding">
                    @{
                        Html.RenderPartial("_DailyPresentAttendance", Model);
                    }
                </div>
             </div>
        </div>
    </div>
</div>

@section scripts
{
    <script>
        $(function () {
            $('body').addClass("pace-done skin-1 mini-navbar");
            $(".chosen-select").chosen({ width: '100%' });
            $.validator.setDefaults({ ignore: ":hidden:not(select)" });
            UpdateChange();
            $("#frmReport").validate({
                rules: {
                    "nLogDate": { required: true },
                    "officeId": {
                        min: 1
                    }
                },
                messages:
                {
                    "nLogDate": {
                        required: 'कृपया विकल्प चयन गर्नुहोस्',
                    },
                    "officeId": {
                        min: 'कृपया विकल्प चयन गर्नुहोस्'
                    }
                }
            });
            $('#nLogDate').nepaliDatePicker({
                onChange: function () {
                    UpdateChange();
                }
            });

            $('.inputmask').inputmask({
                mask: '9999-99-99'
            });
            $('#OfficeId').on('change', function (e) {
                UpdateChange();
            });
            $('#BranchId').on('change', function (e) {
                UpdateChange();
            });
            $('#ServiceId').on('change', function (e) {
                UpdateChange();
            });
            $('#levelId').on('change', function (e) {
                UpdateChange();
            });
            $('#DesignationId').on('change', function (e) {
                UpdateChange();
            });
            function UpdateChange() {
                var nDate = $("#nLogDate").val();
                var officeId = $("#OfficeId").val();
                var branchId = $("#BranchId").val();
                var serviceId = $("#ServiceId").val();
                var levelId = $("#LevelId").val();
                var designationId = $("#DesignationId").val();
                //var empId = $("#empId").val();
                if (nDate == null || nDate == "" || nDate == "____-__-__" || officeId <= 0)
                    return;

                $.ajax({
                    type: "POST",
                    url: '@Url.Action("GetEmpployeeListAccordingToOfficeAndPerDateWithAllOrSelect", "Report")',

                    data: {
                        "officeId": officeId,
                        "nLogDate": nDate,
                        "branchId": branchId,
                        "serviceId": levelId,
                        "levelId": serviceId,
                        "designationId": designationId,
                        "GenerateReportStatus": true,
                        "withSelect": false


                    },





                    cache: false,
                    success: function (data) {
                        $("#EmployeeId").empty();
                        var $prevGroup, prevGroupName;
                        $.each(data, function () {
                            if (this.Group == null) { $("<option />").val(this.Value).text(this.Text).appendTo('#EmployeeId'); }
                            else {
                                if (prevGroupName != this.Group.Name) { $prevGroup = $('<optgroup />').prop('label', this.Group.Name).appendTo('#EmployeeId'); }
                                $("<option />").val(this.Value).text(this.Text).appendTo($prevGroup);
                                prevGroupName = this.Group.Name;
                            }
                        });
                        $("#EmployeeId").trigger('chosen:updated');
                    },
                    error: function () {
                        alert("Failed to load Item");
                    }
                });
            }




            $("#LevelId").chosen().change(function () {

                var levelId = $(this).val();
                $.getJSON("@Url.Action("GetDesignationByLevelId", "Utility")", { LevelId: levelId, withAll: true, withSelect: false },
                 function (data) {
                     $("#DesignationId").empty();
                     var $prevGroup, prevGroupName;
                     $.each(data, function () {
                         if (this.Group == null) { $("<option />").val(this.Value).text(this.Text).appendTo('#DesignationId'); }
                         else {
                             if (prevGroupName != this.Group.Name) { $prevGroup = $('<optgroup />').prop('label', this.Group.Name).appendTo('#designationId'); }
                             $("<option />").val(this.Value).text(this.Text).appendTo($prevGroup);
                             prevGroupName = this.Group.Name;
                         }
                     });
                     $("#DesignationId").trigger('chosen:updated');
                 });
            });

            $('#btnPrint').on('click', function () {
                // var mywindow = window.open('', '', 'height=400,width=600');


                printReport('Daily Presence Attendance Report');
              
            });

        });


 
    </script>
}







@using eAttendance.Models
@model  eAttendance.ReportModel.EmployeeAttendanceList
@{
    eAttendance.Models.ApplicationDbContext db = new eAttendance.Models.ApplicationDbContext();
}
<div id="datatables_table_0_wrapper">
    @if (Model.YearId != 0 && Model.MonthId != 0 && Model.OfficeId != 0)
    {
        <table class="table table-bordered table-condensed" cellpadding="0" style="width:100%;">
            <thead>
                @{

        int nYear = Model.YearId;
        int nMonth = Model.MonthId;


        DateTime[] date = NepaliDateConverter.GetMonth(nYear, nMonth);
        int dayinmonth = Convert.ToInt32((date[1] - date[0]).TotalDays) + 1;
        int totalcolumn = dayinmonth + 3;
                }
                <tr class="no-borders bg-white">
                    <td colspan="@totalcolumn" class="no-borders bg-white text-center">

                        <img src="@Url.Content("~/Images/Emblem_of_Nepal.png")" width="80" height="80" />
                        <h4>नेपाल सरकार</h4>
                        <h5>@eAttendance.Utility.GetOfficeIdNameWithSelect(User).First(w => w.Value == ((Request["officeId"] != null) ? Request["officeId"] : "0")).Text</h5>
                        <h5>
                            @if (Model.OfficeId > 0)
                            {
                                @db.OfficeSetUp.Where(x => x.OfficeId == Model.OfficeId).FirstOrDefault().Address
                            }
                        </h5>


                        <h5>( उपस्थित अनुपस्थित )</h5>
                    </td>
                </tr>

                <tr class='no-border-row bg-white'>

                    <td colspan="34">
                        <table class="table no-borders no-margins">


                            <tr class="no-border-row">
                                <td class="no-borders">साल:@Model.YearId</td>
                                <td class="no-borders">@eAttendance.Service.MenuService.Month: @Html.Raw(Utility.NepaliMonthList().First(w => w.Value == ((Model.MonthId == 0) ? "1" : Model.MonthId.ToString())).Text)</td>
                                @*<td class="no-borders">@eAttendance.Service.MenuService.Month: @Html.Raw(Utility.NepaliMonthList().First(w => w.Value == ((Request["nMonthId"] == null) ? "1" : Request["nMonthId"])).Text)</td>*@
                                <td class="no-borders">कार्यालय: @Html.Raw((Model.OfficeId > 0) ? eAttendance.Utility.GetOfficeInfoByOfficeId(Model.OfficeId).OfficeName : "सबै")</td>
                                <td class="no-borders">सेवा: @Html.Raw((Model.ServiceId > 0) ? eAttendance.Utility.GetServiceByServiceId(Model.ServiceId).ServiceName : "सबै")</td>
                            </tr>
                            <tr class="no-border-row">
                                <td class="no-borders">शाखा: @Html.Raw((Model.BranchId > 0) ? eAttendance.Utility.GetBranchByMainBranchId(Model.BranchId).BranchName : "सबै")</td>
                                <td class="no-borders">तह: @Html.Raw((Model.LevelId > 0) ? eAttendance.Utility.GetLevelByLevelId(Model.LevelId).LevelName : "सबै")</td>
                                <td class="no-borders">पद: @Html.Raw((Model.DesignationId > 0) ? eAttendance.Utility.GetDesignationByDesignationId(Model.DesignationId).DesignationName : "सबै")</td>
                                <td class="no-borders">कर्मचारी: @Html.Raw((Model.EmployeeId > 0) ? eAttendance.Utility.GetEmployeeInfoByEmnployeeId(Model.EmployeeId).EmployeeNameNp : "सबै")</td>
                                <td class="no-borders"></td>
                            </tr>

                        </table>
                    </td>
                </tr>

                <tr>
                    <th rowspan="2" class="text-center">@eAttendance.Service.MenuService.SNo</th>
                    <th rowspan="2" class="text-center">पद</th>
                    <th rowspan="2" class="text-center col-md-2">कर्मचारी</th>
                    @for (int i = 1; i <= dayinmonth; i++)
                    {
                        <th class="text-center th-padding-xs">
                            @NepaliDateConverter.ConvertToNepaliShortDayName(date[0].AddDays(i - 1)) <br />
                        </th>
                    }
                    <th>
                        जम्मा उपस्थित दिन
                    </th>
                    <th>
                        जम्मा काज दिन
                    </th>
                    <th>
                        जम्मा बिदा लिएको दिन
                    </th>
                    <th>
                        जम्मा अनुपस्थित दिन
                    </th>
                </tr>
                <tr>
                    @for (int i = 1; i <= dayinmonth; i++)
                    {
                        <th class="text-center th-padding-xs">
                            @EnglishToNepaliNumber.ConvertToNepaliNumber(i)
                        </th>
                    }
                </tr>
               
            </thead>
            <tbody>
                @{ int count = 0;
                 DateTime[] datetime = NepaliDateConverter.GetMonth(nYear, nMonth);
                 DateTime FromDate = datetime[0];
                 DateTime ToDate = datetime[1];
                }

                @if (Model != null)
                {
                    string CodeName = string.Empty;
                    foreach (var e in Model.EmployeeAttendanceLists)
                    {
                        var employee =
                            db.EmployeeInfo.Where(x => x.EmployeeId == e.EmployeeId).FirstOrDefault();


                        CodeName = employee.EmployeeNameNp + "[" + employee.EmployeeNo + "]";
                        var transfer = false;

                        decimal PresentdaysCount = 0;
                        decimal AbsentdaysCount = 0;
                        
                        decimal VisitdaysCount = 0;
                        decimal LeavedaysCount = 0;

                        count += 1;
                        var attendance = @ReportService.ReportService.GetEmployeeAttandaneByOfficeWithInDateRange(e.EmployeeId, e.OfficeId, FromDate, ToDate);
                        <tr>
                            <td>@count</td>
                            <td>@Html.Raw(eAttendance.Utility.GetDesignationByDesignationId(e.DesignationId).DesignationName ?? "")</td>
                            <td>@CodeName</td>
                            @foreach (var m in attendance.OrderBy(w => w.DesignationId))
                            {
                             
                                var data = db.TransferModel.Where(x => x.TransferDateTime <= m.LogDate).Where(x => x.EmployeeId == e.EmployeeId).FirstOrDefault();
                                if (data != null)
                                {
                                    transfer = true;
                                }
                                if (transfer)
                                {
                                    m.StatusType = 4;
                                }
                                var css = "";
                                if (m.LogDate > DateTime.Now)
                                {
                                    css = "#FFFFFF";
                                }
                                else if (m.StatusType == 4)
                                {
                                    css = "yellow";
                                }
                                else if (m.StatusType == 1)
                                {
                                    css = "#d1dade";
                                }
                                else
                                {
                                    if (m.Holiday != null && m.Holiday.Length > 0)
                                    {
                                        css = "#1c84c6";
                                    }

                                    else if (m.OnLeave != null && m.OnLeave.Length > 0)
                                    {
                                        css = "#23c6c8";
                                    }
                                    else if (m.OnVisit != null && m.OnVisit.Length > 0)
                                    {
                                        css = "#ff00dc";
                                    }
                                    else if (m.WorkType == 3)
                                    {
                                        css = "#4cff00";
                                    }

                                    else
                                    {
                                        css = "#ed5565";
                                    }
                                }
                                <td style="background:@css !important;">
                                    @if (m.LogDate > DateTime.Now)
                                    {
                                        @Html.Raw("")
                                    }

                                    else if (m.StatusType == 4)
                                    {
                                        @Html.Raw("सरु")
                                    }
                                    else if (m.StatusType == 1)
                                    {
                                        PresentdaysCount += 1;
                                        @Html.Raw("उ")
                                    }
                                    else
                                    {
                                        string remarks = "";
                                        if (m.Holiday != null && m.Holiday.Length > 0)
                                        {
                                            string[] h = m.Holiday.Split(' ');
                                            remarks += m.Holiday + " "; //"स.बि"; //h[0].PadLeft(1) + (h.Length > 1 ? "." + h[1].PadLeft(1) : "");
                                        }

                                        if (m.OnLeave != null && m.OnLeave.Length > 0)
                                        {
                                            LeavedaysCount += 1;
                                            string[] l = m.OnLeave.Split(' ');
                                            remarks += m.OnLeave + " "; //"बि"; //l[0].PadLeft(1) + (l.Length > 1 ? "." + l[1].PadLeft(1) : "");
                                            //remarks += m.OnLeave;
                                        }
                                        if (m.OnVisit != null && m.OnVisit.Length > 0)
                                        {
                                            VisitdaysCount += 1;
                                            string[] v = m.OnVisit.Split(' ');
                                            remarks += m.OnVisit + " "; //"का"; //v[0].PadLeft(1) + (v.Length > 1 ? "." + v[1].PadLeft(1) : "");
                                            //remarks += m.OnVisit;
                                        }
                                        if (m.WorkType == 3)
                                        {
                                            remarks += "स";
                                        }

                                        if (remarks.Length == 0)
                                        {
                                            remarks = "अ";
                                            AbsentdaysCount += 1;
                                        }
                                        @Html.Raw(remarks);
                                    }
                                </td>
                            }
                                <td>@PresentdaysCount</td>
                            <td>
                                @VisitdaysCount
                            </td>
                            <td>
                                @LeavedaysCount
                            </td>
                                <td>@AbsentdaysCount</td>
                        </tr>
                    }
                    if (count == 0)
                    {
                        <tr>
                            <td class="text-center alert-info" colspan="35">@eAttendance.Service.MenuService.NoRecordFound</td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" style="background: #d1dade !important">उपस्थित = उ</th>
                    <th colspan="5" style="background: #ed5565 !important">अनुपस्थित = अ</th>
                    <th colspan="5" style="background: #4cff00 !important">सप्ताह = स</th>
                    <th colspan="5" style="background: #23c6c8 !important">बिदा = *बि</th>
                    <th colspan="5" style="background: #1c84c6 !important">सार्वजनिक बिदा = *स.बि</th>
                    <th colspan="5" style="background: #ff00dc !important">काज = *का</th>
                    <th colspan="5" style="background: yellow !important">सरुवा भएको या कार्यालय संग सम्बन्धित नरहेको = *सरु</th>
                </tr>
            </tfoot>
        </table>
    }
</div>


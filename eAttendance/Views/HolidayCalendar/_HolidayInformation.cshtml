@model PagedList.IPagedList<eAttendance.Models.HolidayCalender>
@using PagedList.Mvc;
@{
    Layout = "~/Views/Shared/_Blank.cshtml";
}
<div class="ibox-content">
    <div class="project-list">
        <table id="tblHoliday" class="table table-hover">
            <thead>
                <tr>
                    <th>क्र सं</th>
                    <th>सार्वजनिक बिदाको प्रकार</th>
               
                    <th>कार्यालय</th>
                    <th>मिति देखि</th>
                    <th>मिति सम्म</th>
                    @if (User.IsInRole("SuperAdmin"))
                    {
                    <th class="hidden-print text-center">Action</th>
                        }
                </tr>
            </thead>
            <tbody>
                @{int count = ((Model.PageNumber - 1) * Model.PageSize);}
                @foreach (var m in Model)
                {
                    count += 1;
                    <tr>
                        <td>@count</td>
                        <td>
                            @Html.Raw(m.HolidayTypeName)
                            <span class="pull-right">
                                @if (m.ApplicableFor == 1)
                                {
                                    <text> Male/Female</text>

                                }
                                else if (m.ApplicableFor == 2)
                                {
                                    <text> Male</text>
                                }
                                else if (m.ApplicableFor == 3)
                                {
                                    <text> Female</text>
                                }
                            </span>

                        </td>
                   
                        <td>@Html.Raw((m.OfficeId != null && m.OfficeId > 0) ? eAttendance.Utility.GetOfficeIdName(User).Where(x => x.Value == m.OfficeId.ToString()).FirstOrDefault().Text : "")</td>
                        <td>@eAttendance.NepaliDateConverter.ConvertToNepali(m.FromDate)</td>
                        <td>@eAttendance.NepaliDateConverter.ConvertToNepali(m.ToDate)</td>
                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Administrator"))
                            {
                        <td class="project-actions hidden-print col-md-2">
                            <button value="@m.HolidayCalendarId" type="button" class="btn-edit btn btn-primary btn-sm"><i class="fa fa-pencil"></i> <span class="hidden-xs hidden-sm"></span> </button>
                            <button value="@m.HolidayCalendarId" class="btn-delete btn btn-sm btn-danger"><i class="fa fa-remove"></i><span class="hidden-xs hidden-sm"></span> </button>
                        </td>
                            }
                    </tr>
                }
            </tbody>
        </table>
        <div class="row">
            <div class=" col-md-3 col-sm-3">
                <div class="pull-left">
                    page @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) of @Model.PageCount
                </div>
            </div>
            <div class=" col-md-9 col-sm-9">
                @Html.PagedListPager(Model, page => Url.Action("Index", new { search = ViewBag.Search, page, sortOrder = ViewBag.CurrentSort }))
            </div>
        </div>
    </div>
</div>




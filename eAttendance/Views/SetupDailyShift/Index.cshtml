@model IEnumerable<eAttendance.Models.ShiftType>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Setup Daily Shift";
}

<div class="wrapper wrapper-content">
    <div class="modal-content">
        <div class="modal-header">
            <ol class="breadcrumb">
                <li>सेटअप</li>
                <li><a href="@Url.Action("Index","SetupDailyShift")">दैनिक शिफ्ट सेटअप</a></li>
                <li>शिफ्टका सूचीहरु</li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <div class="row wrapper white-bg page-heading hidden-print">
                        <div class="col-lg-10">
                            <h2>दैनिक शिफ्ट सेटअप</h2>
                        </div>
                        <div class="col-lg-2 text-right">
                            <button class="btn btn-primary btn-sm"
                                    onclick="location.href='@Url.Action("Add","SetupDailyShift")'">
                                नयाँ बनाउनु
                            </button>
                        </div>
                    </div>
                </div>

                <div class="ibox-content">
                    <table id="tblSetupShift" class="table table-hover table-condensed">
                        <thead>
                            <tr>
                                <th>क्र सं</th>
                                <th>नाम</th>
                                <th>स्थिति</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int count = 0; }

                            @foreach (var m in Model)
                            {
                                count++;

                                <tr>
                                    <td>@count</td>
                                    <td>@m.Name</td>

                                    <td>
                                        @if (m.IsActive)
                                        {
                                            <span class="label label-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="label label-danger">Inactive</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <button class="btn btn-primary btn-sm"
                                                onclick="location.href='@Url.Action("Edit","SetupDailyShift", new { id = m.ShiftTypeId })'">
                                            <i class="fa fa-pencil"></i>
                                        </button>

                                        <button value="@m.ShiftTypeId"
                                                class="btn btn-danger btn-sm btn-delete">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modelDelete" role="dialog"></div>

@section Scripts
{
    <script>
    $(document).ready(function () {

        $('#tblSetupShift tbody').on('click', '.btn-delete', function () {

            var id = $(this).val();

            $.ajax({
                url: '@Url.Action("Delete", "SetupDailyShift")',
                type: 'GET',
                data: { id: id },
                success: function (result) {
                    $("#modelDelete").html(result);
                    $("#modelDelete").modal('show');
                },
                error: function () {
                    alert("Error loading delete confirmation");
                }
            });

        });

    });
    </script>
}
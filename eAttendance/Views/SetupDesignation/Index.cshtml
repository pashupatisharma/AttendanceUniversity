@model PagedList.IPagedList<eAttendance.Models.DesignationSetUp>
@using PagedList.Mvc;
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Setup Designation";
}

<div class="row wrapper white-bg page-heading hidden-print">
    <div class="modal-content">
        <div class="modal-header">
            <ol class="breadcrumb">
                <li class="animated fadeInUp">सेटअप</li>
                <li class="animated fadeInLeft"><a href="@Url.Action("Index","SetupDesignation")">पद सेटअप</a></li>
                <li class="animated fadeInRight">पदका सूचीहरु</li>

            </ol>
        </div>
    </div>

    <div class="col-lg-10">
        <h2>पद  सेटअप</h2>

    </div>
    <div class="col-lg-2">
        <div class="title-action hidden-print">
            <button class="btn btn-primary btn-sm btn-add" onclick="location.href='@Url.Action("Add","SetupDesignation")'">नयाँ बनाउनु </button>
        </div>
    </div>
</div>
<div class="col-lg-12">
    <div class="card">
        <div class="card-header bg-info">
            <h2 class="m-b-0 text-info">पद सेटअप  </h2>
        </div>
        <div class="card-body">
            <div class="ibox-content no-border-bottom">
                @using (Html.BeginForm("Index", "SetupDesignation", FormMethod.Get, new { @class = "form-view-data", @id = "frmSetupDesignation" }))
                {
                <fieldset>
                    <legend>Search Criteria</legend>
                    <div class="row">
                        <div class="col-sm-3">
                            <div class="form-group">
                                <label class="control-label">तह</label>
                                @Html.DropDownList("slevel", Utility.GetLevelIdName(), new { @class = "chosen-select form-control chosen-select" })
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-group">
                                <label class="control-label">पद</label>
                                @Html.TextBox("sdesignation", (string)ViewBag.sdesignation, new { @class = "form-control" })
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-group margin-top-25">
                                <button type="submit" class="btn-Search btn btn-primary btn-rounded btn-outline fa fa-search"> खोज्नुहोस्</button>
                            </div>
                        </div>
                    </div>
                </fieldset>
                }
            </div>
        
        <div class="ibox mt-15">
            
            <div class="ibox-content">
                <div class="project-list">
                    <table id="tblDesignation" class="table  table-striped table-condensed dataTable table-color ">
                        <thead>

                            <tr>
                                <th>SNo</th>
                                <th>पद </th>
                                <th>श्रेणी</th>

                                <th>विवरण</th>
                                <th class="hidden-print action text-center">#</th>
                            </tr>

                        </thead>
                        <tbody>


                            @{int count = 0;}
                            @foreach (var m in Model.OrderBy(m => m.DisplayOrder))
                            {
                                <tr>
                                    @if (m.Status == 1)
                                    {
                                        <td>@Html.Raw((count += 1))</td>
                                        <td class="project-title">
                                            <strong>@m.DesignationName</strong><br />
                                        </td>
                                        <td>
                                            @m.LevelSetUp.LevelName
                                        </td>

                                        <td>@m.Description</td>
                                        <td class="project-actions hidden-print">
                                            <button type="button" class="btn-edit btn btn-primary btn-sm" onclick="location.href='@Url.Action("Edit","SetupDesignation",new {@id=m.DesignationId })'"><i class="fa fa-pencil"></i> <span class="hidden-xs hidden-sm"></span> </button>
                                            <button value="@m.DesignationId" class="btn-delete btn btn-sm btn-danger"><i class="fa fa-remove"></i><span class="hidden-xs hidden-sm"></span> </button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="row">
                        <div class=" col-md-3 col-sm-3">
                            <div class="pull-left">

                                @{ var pager = (PagedList.IPagedList)Model;}
                                page @(pager.PageCount < pager.PageNumber ? 0 : pager.PageNumber) of @pager.PageCount
                            </div>
                        </div>
                        <div class=" col-md-9 col-sm-9">


                            @Html.PagedListPager((PagedList.IPagedList)Model, page => Url.Action("Index", new { page = page }), PagedListRenderOptions.OnlyShowFivePagesAtATime)


                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

<div class="modal inmodal fade" id="modelDelete" role="dialog">

</div>
@section Scripts
{
    <script type="text/javascript">
        $(document).ready(function () {
            $('.chosen-select').chosen();
            toastr.options = {
                "progressBar": true,
                "positionClass": "toast-top-center",
                "preventDuplicates": false,
                "showDuration": "300",
                "hideDuration": "1000",
                "timeOut": "5000",
                "extendedTimeOut": "1000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut"
            }
            var hasMessage = '@TempData["HasMessage"]';
            if (hasMessage) {
                Command: toastr["@TempData["MessageType"]"]("@TempData["Message"]", "@TempData["MessageHeader"]")
            }

         
            $('.btn-delete').on('click', function () {
                var designationId = $(this).attr('value');
                $.ajax({
                    url: '@Url.Action("Delete", "SetupDesignation")',
                    type: 'GET',
                    data: { id: designationId },
                    success: function (result) {
                        console.log(result)
                        $("#modelDelete").html(result);
                        $("#modelDelete").modal('show');
                    },
                    error: function () {
                    }
                });
            })
        })
    </script>
}







@model PagedList.IPagedList<eAttendance.Models.EmployeeInfo>
@using PagedList.Mvc;
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Assign Employee Leave";
}

<div class="row wrapper white-bg page-heading hidden-print">
    <div class="col-lg-8 col-sm-8">
        <h2>निर्धारित बिदा</h2>
        <ol class="breadcrumb ">
            <li>
                <a href="@Url.Action("Index","Home")">घर</a>
            </li>
            <li>
                <a> सेटअप</a>
            </li>
            <li class="active">
                <strong>निर्धारित बिदा</strong>
            </li>
        </ol>
    </div>
    <div class="col-lg-4 col-sm-4">
        <div class="title-action hidden-print">
            <button class="btn btn-primary btn-sm btn-add hide">नयाँ बिदा </button>
            <a href="@Url.Action("AddList", "AssignEmployeeLeave")" class="btn btn-primary"><i class="fa fa-plus"></i> बिदा तोक्नुहोस् </a>
        </div>
    </div>
</div>
<div class="wrapper wrapper-content padding-top-md">
    <div class="ibox float-e-margins no-margins">
        <div class="ibox-title">
            <h5><i class="fa fa-filter"></i> @eAttendance.Service.MenuService.Filter  </h5>
            <div class="ibox-tools">
                <a class="collapse-link">
                    <i class="fa fa-chevron-up"></i>
                </a>
            </div>
        </div>
        <div class="ibox-content no-border-bottom">

            <div class="row">
                <div class="col-sm-3">
                    <div class="form-group">
                        <label class="control-label">शाखा</label>
                        @Html.DropDownList("Branch", eAttendance.Utility.GetBranchIdName(User), new { @class = "chosen-select form-control chosen-select" })
                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="form-group">
                        <label class="control-label ">सेवा</label>
                        @Html.DropDownList("Service", eAttendance.Utility.GetServiceIdName(User), new { @class = "chosen-select form-control chosen-select" })
                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="form-group">
                        <label class="control-label">तह</label>
                        @Html.DropDownList("Level", eAttendance.Utility.GetLevelIdName(), new { @class = "chosen-select form-control chosen-select" })
                    </div>
                </div>


                <div class="col-sm-3">
                    <div class="form-group">
                        <label class="control-label">पद</label>
                        @Html.DropDownList("Designation", eAttendance.Utility.GetDepartmentIdName(), new { @class = "chosen-select form-control chosen-select" })
                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="form-group">
                        <label class="control-label">साल</label>
                        @Html.DropDownList("FiscalYear", (SelectList)ViewBag.FiscalYears, new { @class = "chosen-select form-control chosen-select" })
                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="form-group">
                        <label class="control-label">कर्मचारी र @eAttendance.Service.MenuService.EmployeeNo</label>
                        @Html.TextBox("Search","", new { @class = "form-control" })
                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="form-group margin-top-25">
                        <button type="button" class="btn-Search btn btn-primary btn-rounded btn-outline fa fa-search"> खोज्नुहोस्</button>
                    </div>
                </div>
            </div>

            <div id="AssignLeave" class="row">
                @Html.Action("List", "AssignEmployeeLeave")',
            </div>
        </div>
    </div>

</div>


<div class="modal inmodal fade" id="modelAdd" role="dialog">
  
</div>


@section Scripts
{

    <script type="text/javascript">
        $(document).ready(function () {
            $("#Level").chosen().change(function () {
                // Loading Designation
                var levelId = $(this).val();
                $.getJSON("@Url.Action("GetDesignationByLevelId", "Utility")", { LevelId: levelId, withAll: true, withSelect: false },
                 function (data) {
                     $("#Designation").empty();
                     var $prevGroup, prevGroupName;
                     $.each(data, function () {
                         if (this.Group == null) { $("<option />").val(this.Value).text(this.Text).appendTo('#Designation'); }
                         else {
                             if (prevGroupName != this.Group.Name) { $prevGroup = $('<optgroup />').prop('label', this.Group.Name).appendTo('#Designation'); }
                             $("<option />").val(this.Value).text(this.Text).appendTo($prevGroup);
                             prevGroupName = this.Group.Name;
                         }
                     });
                     $("#Designation").trigger('chosen:updated');
                 });
            });

            toastr.options = {
                "progressBar": true,
                "positionClass": "toast-top-center",
                "preventDuplicates": false,
                "showDuration": "300",
                "hideDuration": "1000",
                "timeOut": "5000",
                "extendedTimeOut": "1000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut"
            }
            var hasMessage = '@TempData["HasMessage"]';
            if (hasMessage)
            {
                Command: toastr["@TempData["MessageType"]"]("@TempData["Message"]", "@TempData["MessageHeader"]")
            }


        $('.btn-add').on('click', function () {
            $.ajax({
                url: '@Url.Action("Add", "AssignEmployeeLeave")',
                type: 'GET',
                data: { },
                success: function (result) {
                    console.log(result)
                    $("#modelAdd").html(result);
                    $("#modelAdd").modal('show');
                },
                error: function () {
                }
            });
        })
        $('.btn-edit').on('click', function () {
            var assignleaveId = $(this).attr('value');
            $.ajax({
                url: '@Url.Action("Edit", "AssignEmployeeLeave")',
                type: 'GET',
                data: { id: assignleaveId },
                success: function (result) {
                    console.log(result)
                    $("#modelEdit").html(result);
                    $("#modelEdit").modal('show');
                },
                error: function () {
                }
            });
        })
        $('.btn-delete').on('click', function () {
            var assignleaveId = $(this).attr('value');
            $.ajax({
                url: '@Url.Action("Delete", "AssignEmployeeLeave")',
                type: 'GET',
                data: { id: assignleaveId },
                success: function (result) {
                    console.log(result)
                    $("#modelDelete").html(result);
                    $("#modelDelete").modal('show');
                },
                error: function () {
                }
            });
        })
    })
    </script>

    <script>
        $('.btn-Search').on('click', function () {
            var branch = $('#Branch').val();
            var service = $('#Service').val();
            var level = $('#Level').val();
            var designation = $('#Designation').val();
            var fiscalyear = $('#FiscalYear').val();
            var search = $('#Search').val();

            $.ajax({
                url: '@Url.Action("List", "AssignEmployeeLeave")',
                type: 'POST',
                data: { branchId: branch,serviceId:service,levelId:level,designationId:designation,search:search,fiscalYearId:fiscalyear},
                beforeSend: function () {
                    $('#modalLoading').modal('show');
                },
                complete: function () {
                    $('#modalLoading').modal('hide');
                },
                success: function (result) {
                    $('#AssignLeave').html(result);
                },
                error: function () {
                    alert('Error occured while loading employee leave');
                }
            });
        });
    </script>
}



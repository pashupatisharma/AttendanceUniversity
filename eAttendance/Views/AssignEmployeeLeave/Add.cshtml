@model eAttendance.Models.AssignEmployeeLeave
@{
    Layout = "~/Views/Shared/_Blank.cshtml";
}
<div class="modal-dialog">
    <div class="modal-content">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">×</span><span class="sr-only">Close</span></button>
            <h4 class="modal-title">थप निर्धारित बिदा</h4>
            <small class="font-bold"></small>
        </div>
        @using (Html.BeginForm("Add", "AssignEmployeeLeave", FormMethod.Post, new { @id = "frmAddAssignEmployeeLeave", @class = "form-horizontal" }))
        { 
            <div class="modal-body">
                <div class="form-group">
                    @Html.HiddenFor(m => m.OfficeId)
                    <label class="col-sm-3 control-label">@Html.DisplayNameFor(m => m.FiscalYearId)</label>
                    <div class="col-sm-9">
                       @* @Html.DropDownListFor(m => m.FiscalYearId, eAttendance.Utility.YearListWithSelect(), new { @class = "chosen-select form-control" })*@
                    </div>
                </div>
                <div class="form-group">
                    <label class="col-sm-3 control-label">@Html.DisplayNameFor(m => m.EmployeeId)</label>
                    <div class="col-sm-9">
                        @*@Html.DropDownListFor(m => m.EmployeeId, EmployeeProvider.GetEmployeeIdByUserName(User), new { @class = "chosen-select form-control" })*@
                    </div>
                </div>
                <div class="form-group">
                    <label class="col-sm-3 control-label">@Html.DisplayNameFor(m => m.LeaveTypeId)</label>
                    <div class="col-sm-9">
                        @Html.DropDownListFor(m => m.LeaveTypeId, Enumerable.Empty<SelectListItem>(), new { @class = " chosen-select form-control" })
                    </div>
                </div>
                <div class="form-group">
                    <label class="col-sm-3 control-label">@Html.DisplayNameFor(m => m.OpenningBalance)</label>
                    <div class="col-sm-9">
                        @Html.TextBoxFor(m => m.OpenningBalance, new { @class = "form-control" })
                    </div>
                </div>

                <div class="form-group">
                    <label class="col-sm-3 control-label">@Html.DisplayNameFor(m => m.NoOfLeave)</label>
                    <div class="col-sm-9">
                        @Html.TextBoxFor(m => m.NoOfLeave, new { @class = "form-control" })
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary btn-sm">बचत गर्नु</button>
                <button type="button" class="btn btn-danger btn-sm" data-dismiss="modal">बन्द गर्नु</button>
            </div>
        }
    </div>
</div>
@section scripts
{
    <script>
        $(document).ready(function () {
            $(".chosen-select").chosen({ width: '100%' });
            $.validator.setDefaults({ ignore: ":hidden:not(select)" });

            
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("LoadLeaveType", "SetupLeaveType")',
                    data: null,
                    contentType: "application/json; charset=utf-8",
                    dataType: 'json',
                    cache: false,
                    success: function (data) {
                        $('#LeaveTypeId').val(data);

                        $('#LeaveTypeId').get(0).options.length = 0;
                        $('#LeaveTypeId').get(0).options[0] = new Option("बिदा किसिम छान्नुहोस....", "0");
                        $.map(data, function (item) {
                            $('#LeaveTypeId').get(0).options[$('#LeaveTypeId').get(0).options.length] = new Option(item.Text, item.Value);
                        });
                        $('#LeaveTypeId').trigger('chosen:updated');
                    },
                    error: function () {
                        //alert("Failed to load Item");
                    }
                });
            

            $("#frmAddAssignEmployeeLeave").validate({
                rules: {
                    FiscalYearId: {
                        required: true,
                        minlength: 3,
                        remote: {
                            url: "@Url.Action("CheckDuplicate", "AssignEmployeeLeave")",
                            type: "POST",
                            data: {
                                FiscalYearId: function () {
                                    return $("#FiscalYearId").val();
                                }
                            }
                        }
                    },
                    Year: {
                        min: 1
                    },
                    EmployeeId: {
                        required: true,
                        min: 1
                    },
                    LeaveTypeId: {
                        min: 1
                    }

                },
                messages: {
                    EmployeeId: {
                        remote: "Duplicate employee name found. Please use another name."
                    },
                    Year: {
                        min: "Please select an option."
                    },
                    EmployeeId: {
                        min: "Please select an option."
                    },
                    LeaveTypeId: {
                        min: "Please select an option."
                    }
                }
            });

            $('#LeaveTypeId').change(function () {
                LoadDefaultValue(this.value);
            });

            function LoadDefaultValue(leaveTypeId) {
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("LoadDefaultValue", "AssignEmployeeLeave")',
                    data: "{'leaveTypeId':'" + leaveTypeId + "'}",
                    contentType: "application/json; charset=utf-8",
                    dataType: 'json',
                    cache: false,
                    success: function (data) {
                        $('#NoOfLeave').val(data);
                    },
                    error: function () {
                        //alert("Failed to load Item");
                    }
                });
            }
        });
    </script>
}







@model eAttendance.Models.AssignEmployeeLeave
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    eAttendance.Models.ApplicationDbContext db = new eAttendance.Models.ApplicationDbContext();
}
<div class="modal-content">
    <div class="modal-header">
        <ol class="breadcrumb">
            <li class="animated fadeInUp">बिदा सेटअप</li>
            <li class="animated fadeInLeft"><a href="@Url.Action("AddList","AssignEmployeeLeave")">बिदा नियुक्ति सेटअप</a></li>
            <li class="animated fadeInRight">बिदा नियुक्तिका सूचीहरु</li>

        </ol>
    </div>
</div>

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-lg-8">
        <h2>निर्धारित छुट्टी</h2>
    
    </div>

</div>
<div class="wrapper wrapper-content no-padding padding-top-md">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-content no-border-bottom">
                    @using (Html.BeginForm("AddList", "AssignEmployeeLeave", FormMethod.Get, new { @class = "form-view-data" }))
                    {
                        <div class="row">
                            <div class="col-sm-2">
                                <div class="form-group">
                                    <label class="control-label">@eAttendance.Service.MenuService.FiscalYear</label>
                                    @Html.DropDownList("FiscalYear", Utility.GetFiscalList(), new { @class = "chosen-select form-control chosen-select" })

                                </div>
                            </div>
                            <div class="col-sm-2">
                                <div class="form-group">
                                    <label class="control-label">@Html.DisplayNameFor(m => m.OfficeId)</label>
                                    @Html.DropDownList("OfficeId", Utility.GetOfficeIdNameWithSelect(User), new { @class = "chosen-select form-control chosen-select" })

                                </div>
                            </div>

                            <div class="col-sm-2">
                                <div class="form-group">
                                    <label class="control-label">&nbsp;</label>
                                    <button type="submit" class="btn-Search btn btn-primary btn-rounded btn-outline form-control fa fa-search"> खोज्नुहोस्</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @using (Html.BeginForm("SaveAssignLeave", "AssignEmployeeLeave"))
                {
                    @Html.HiddenFor(m => m.OfficeId)
                    @Html.HiddenFor(m => m.FiscalYearId)
                    <div class="hr-line-dashed"></div>
                    <table id="AssignTableLeaveId" class="table table-condensed table-bordered table-color ">
                        <thead>
                            <tr>
                                <th rowspan="3" class="text-center center" width="140px" style="width:140px; vertical-align: inherit;">
                                    कर्मचारीको नाम
                                </th>
                                @foreach (var lt in db.LeaveTypeSetUp.ToList())
                                {
                                    <th colspan="2" class="text-center">@lt.LeaveTypeName</th>
                                }
                            </tr>
                            <tr>
                                @foreach (var lt in db.LeaveTypeSetUp.ToList())
                                {
                                    <th class="text-center">गत वर्ष</th>
                                    <th class="text-center">यो वर्ष</th>
                                }
                            </tr>
                            <tr>
                                @foreach (var lt in db.LeaveTypeSetUp.ToList())
                                {
                                    <th leavetypeid="@lt.LeaveTypeId"><input type="text" class="form-control input-sm text-center LastYearValue" /></th>
                                    <th leavetypeid="@lt.LeaveTypeId"><input type="text" class="form-control input-sm text-center ThisYearValue" /></th>
                                }
                            </tr>
                        </thead>
                        <tbody>



                            @foreach (var item in Model.EmployeeInfo.EmoloyeeList)
                            {
                                item.FiscalYearId = Model.FiscalYearId;
                                Html.RenderPartial("_AddListPartial", item);


                            }
                        </tbody>
                    </table>
                    <div class="hr-line-dashed"></div>
                    <div class="form-group text-center">
                        <input type="submit" id="SaveLeave" class="btn btn-success" title="बचत गर्नु" value="बचत गर्नु" />
                        <a href="@Url.Action("Index","AssignEmployeeLeave")" class="btn btn-danger" type="submit">@eAttendance.Service.MenuService.Cancel</a>
                    </div>
                }




            </div>
        </div>
    </div>
</div>

@section scripts
{
    <script>
        $('body').addClass("pace-done skin-1 mini-navbar");
        $(".chosen-select").chosen({ width: '200px' });
        toastr.options = {
            "progressBar": true,
            "positionClass": "toast-top-center",
            "preventDuplicates": false,
            "showDuration": "300",
            "hideDuration": "1000",
            "timeOut": "5000",
            "extendedTimeOut": "1000",
            "showEasing": "swing",
            "hideEasing": "linear",
            "showMethod": "fadeIn",
            "hideMethod": "fadeOut"
        }

        var save = function () {
            var table = document.getElementById("AssignTableLeaveId");
            var assignemployeeleave = [];
            for (var i = 3, row; row = table.rows[i]; i++) {
                //iterate through rows
                //rows would be accessed using the "row" variable assigned in the for loop

                for (var j = 1, col; col = row.cells[j]; j += 2) {
                    var balance = $(row.cells[j]).find('input').val();
                    var noofleave = $(row.cells[j + 1]).find('input').val();

                    assignemployeeleave.push(
                     {
                         LeaveApplicationId: $(col).attr("AssignTableLeaveIdid"),
                         FiscalYearId: $('#FiscalYear').val(),
                         EmployeeId: $(row.cells[0]).attr("employeeid"),
                         LeaveTypeId: $(col).attr("leavetypeid"),
                         OpenningBalance: (parseInt(balance)) ? balance : 0,
                         NoOfLeave: (parseInt(noofleave)) ? noofleave : 0,
                         CreatedBy: '',
                         CreatedDate: null,
                         ModifiedBy: '',
                         ModifiedDate: null,
                         Status: 1
                     });
                }
            }

            $.ajax({
                url: '@Url.Action("SaveAssignTableLeaveId", "AssignEmployeeLeave")',
                type: 'POST',
                data: { 'assignemployeeleave': assignemployeeleave },
                beforeSend: function () {
                    $('#modalLoading').modal('show');
                },
                complete: function () {
                    $('#modalLoading').modal('hide');
                },
                success: function (result) {
                    Command: toastr['success']("डाटा सफलतापूर्वक सुरक्षित गरिएको छ।", "सफलता सन्देश !")
                    location.reload();
                },
                error: function () {
                    Command: toastr['error']("डाटा बचत गर्दा त्रुटि भयो।", "त्रुटि सन्देश !")
                }
            });
        }

        $("#btnSave").on('click', function () {
            save();
        });

        $(".LastYearValue").on('change', function () {
            var value = $(this).val();
            var leavetypeid = $(this).closest('th').attr('leavetypeid');

            $('#AssignTableLeaveId tbody [assigntype=lastyear][leavetypeid=' + leavetypeid + ']').each(function () {

                $(this).find('input').val(value);
            });
        });

        $(".ThisYearValue").on('change', function () {
            var value = $(this).val();
            var leavetypeid = $(this).closest('th').attr('leavetypeid');

            $('#AssignTableLeaveId tbody [assigntype=thisyear][leavetypeid=' + leavetypeid + ']').each(function () {
                $(this).find('input').val(value);
            });
        });

    </script>
}





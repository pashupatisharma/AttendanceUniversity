@model eAttendance.Models.VisitApplication
@{
    Layout = "~/Views/Shared/_Blank.cshtml";
    
}
@*<script src="~/Scripts/jquery-2.1.3.min.js"></script>*@
    <script type="text/javascript">
    $(function () {
        $('#OfficeId').on('change', function (e) {


            var nYearId = 0;
            var nMonthId = 0;
                var officeId = $("#OfficeId").val();
            var branchId = 0;
            var serviceId = 0;
            var levelId = 0;
            var designationId = 0;


                //int year, int month, int officeId, int branchId = 0, int serviceId = 0, int levelId = 0, int designationId = 0, bool withAll = false, bool withSelect = false
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("GetEmployeeOfSelectedOffice", "Report")',
                    data: "{'year':'" + nYearId + "','month':'" + nMonthId + "','officeId':'" + officeId + "','branchId':'" + branchId + "','serviceId':'" + serviceId + "','levelId':'" + levelId + "','designationId':'" + designationId + "','withAll':'" + true + "','withSelect':'" + false + "'}",
                    contentType: "application/json; charset=utf-8",
                    dataType: 'json',
                    cache: false,
                    success: function (data) {
                        debugger;
                        $("#EmployeeId").empty();
                        var $prevGroup, prevGroupName;
                        $.each(data, function () {
                            if (this.Group == null) { $("<option />").val(this.Value).text(this.Text).appendTo('#EmployeeId'); }
                            else {
                                if (prevGroupName != this.Group.Name) { $prevGroup = $('<optgroup />').prop('label', this.Group.Name).appendTo('#EmployeeId'); }
                                $("<option />").val(this.Value).text(this.Text).appendTo($prevGroup);
                                prevGroupName = this.Group.Name;
                            }
                        });
                        $("#EmployeeId").trigger('chosen:updated');
                    },
                    error: function () {
                        alert("Failed to load Item");
                    }
                });

        });
    });
    </script>
<div class="modal-dialog modal-lg">
    <div class="modal-content">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">×</span><span class="sr-only">Close</span></button>
            <h4 class="modal-title">@eAttendance.Service.MenuService.VisitPosting </h4>
            <small class="font-bold"></small>
        </div>
        @using (Html.BeginForm("AddVisitPosting", "VisitApplication", FormMethod.Post, new { @id = "frmAddVisitApplication" }))
        {
            <div class="modal-body">
                @*@Html.HiddenFor(m => m.VisitApplicationId)*@
                <div class="row">
                    <div class="col-md-8 b-r">
                        <div class="row">
                            <div class="form-group col-md-6">
                                <label class="control-label">@Html.DisplayNameFor(m => m.OfficeId)</label>

                                @Html.DropDownListFor(m => m.OfficeId, Utility.GetOfficeIdNameWithSelect(User), new { @class = "chosen-select form-control" })
                            </div>
                        </div>
                        <div class="row">
                            <div class="form-group col-md-6">
                                <label class="control-label">@Html.DisplayNameFor(m => m.EmployeeId)</label>
                                @{var officeid = eAttendance.EmployeeProvider.GetOfficeIdByUserId(User.Identity.Name);}
                                @Html.DropDownListFor(m => m.EmployeeId, Utility.GetEmployeeListBYUserSuper(officeid, User), new { @class = "chosen-select form-control" })
                            </div>
                            <div class="form-group col-md-6">
                                <label class="control-label">@Html.DisplayNameFor(m => m.VisitTypeId)</label>
                                @Html.DropDownListFor(m => m.VisitTypeId, eAttendance.Utility.GetSetupVisitTypeIdNameByWithAllOrWithSelect(), new { @class = "chosen-select form-control" })
                            </div>
                            <div class="form-group col-md-6 ">
                                <label class="control-label">@Html.DisplayNameFor(m => m.NFromDate)</label>
                                @Html.TextBoxFor(m => m.NFromDate, "{0:yyyy/MM/dd }", new { @class = "form-control inputmask nepali-calendar", data_mask = "9999-99-99" })
                            </div>
                            <div class="form-group  col-md-6">
                                <label class="control-label">@Html.DisplayNameFor(m => m.NToDate)</label>
                                @Html.TextBoxFor(m => m.NToDate, "{0:yyyy/MM/dd }", new { @class = "form-control inputmask nepali-calendar", @mask = "9999-99-99" })
                            </div>
                            <div class="form-group  col-md-12">
                                <label class="control-label">@Html.DisplayNameFor(m => m.Subject)</label>
                                @Html.TextBoxFor(m => m.Subject, new { @class = "form-control" })
                            </div>
                            <div class="form-group  col-md-12">
                                <label class="control-label">@Html.DisplayNameFor(m => m.Message)</label>
                                @Html.TextAreaFor(m => m.Message, new { @class = "form-control", style = "height:160px;" })
                            </div>

                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="row">
                            <div class="form-group col-md-12">
                                <div class="ibox-content">
                                    <div>
                                       
                                        <div class="progress progress-small" style="height: 5px;">
                                            <div style="width: 100%; height:5px;" class="progress-bar"></div>
                                        </div>
                                       
                                        <div class="progress progress-small" style="height: 5px;">
                                            <div style="width: 100%;" class="progress-bar progress-bar-danger"></div>
                                        </div>
                                        <div>
                                            <span class="font-bold">Days Count</span>
                                            <small class="pull-right">
                                                <label class="control-label" id="lblDaysCount">0</label>
                                            </small>
                                        </div>
                                        <div class="progress progress-small" style="height: 5px;">
                                            <div style="width: 100%;" class="progress-bar progress-bar-navy-light"></div>
                                        </div>
                                    </div>
                                    <label style="color:red" id="lblMessage"></label>
                                </div>
                            </div>
                          

                            <div class="form-group  col-md-6">
                                <label class="control-label">@Html.DisplayNameFor(m => m.Recomender)</label>
                                @Html.DropDownListFor(m => m.Recomender, eAttendance.Utility.GetEmployeeRecommederListAll(User), new { @class = "chosen-select form-control" })
                            </div>
                            <div class="form-group  col-md-6">
                                <label class="control-label">@Html.DisplayNameFor(m => m.ApprovedBy)</label>
                                @Html.DropDownListFor(m => m.ApprovedBy, eAttendance.Utility.GetEmployeeApproverListAll(User), new { @class = "chosen-select form-control" })
                            </div>


                            <div class="form-group  col-md-12">
                                <label class="control-label">@Html.DisplayNameFor(m => m.NApprovedDate)</label>
                                @Html.TextBoxFor(m => m.NApprovedDate, "{0:yyyy/MM/dd }", new { @class = "form-control inputmask nepali-calendar", @mask = "9999-99-99", @id = "NApprovedDateEdit" })
                            </div>
                          
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary btn-sm">बचत गर्नु</button>
                <button type="button" class="btn btn-danger btn-sm" data-dismiss="modal">बन्द गर्नु</button>
            </div>
        }
    </div>
</div>
@section scripts
{
    <script src="~/Scripts/plugins/jasny/jasny-bootstrap.min.js"></script>
    <script>
    $(document).ready(function () {
        $('.nepali-calendar').nepaliDatePicker(
            {
                onChange: function () {
                    CalculateDays();
                    //var empId = $('#EmployeeId').val();
                    //CheckEmployeeIsInLeaveOrNot(empId, fromDate, toDate);
                }
            });
        $(".chosen-select").chosen({ width: '100%' });

        $.validator.setDefaults({ ignore: ":hidden:not(select)" })
        $('.i-checks').iCheck({
            checkboxClass: 'icheckbox_square-blue',
            radioClass: 'iradio_square-blue',
        });     

        $(document).on('change', '#NFromDate', function () {
            CalculateDays();
        });
        
        $(document).on('change', '#NToDate', function () {
            CalculateDays();
        });

       


        $("#frmAddVisitApplication").validate({
            rules: {
                EmployeeName: {
                    required: true,
                    minlength: 3,
                    remote: {
                        url: "@Url.Action("CheckDuplicate", "VisitApplication")",
                        type: "POST",
                        data: {
                            EmployeeName: function () {
                                return $("#EmployeeName").val();
                            }
                        }
                    }
                },
                NApprovedDate: {
                    required: true,
                },
                NFromDate: {
                    required: true,
                },
                NToDate: {
                    required: true,
                },
                EmployeeId: {
                    min: 1
                },
                VisitTypeId: {
                    min: 1
                },
                Recomender: {
                    min: 1
                },
                ApprovedBy: {
                    min: 1
                }
            },
            messages: {
                EmployeeName: {
                    remote: "Duplicate employee Name found. Please use another name."
                },
                EmployeeId: {
                    min: 'कृपया विकल्प चयन गर्नुहोस्'
                },
                VisitTypeId: {
                    min: 'कृपया विकल्प चयन गर्नुहोस्'
                },
                ApprovedBy: {
                    min: 'कृपया विकल्प चयन गर्नुहोस्'
                },
                Recomender: {
                    min: 'कृपया विकल्प चयन गर्नुहोस्'
                },
                NApprovedDate: {
                    required: 'कृपया आवश्यक जानकारी भर्नुहोस्'
                },
                NFromDate: {
                    required: 'कृपया आवश्यक जानकारी भर्नुहोस्'
                },
                NToDate: {
                    required: 'कृपया आवश्यक जानकारी भर्नुहोस्'
                }
            }
        });

       
       
        function CalculateDays() {
            debugger;
            $("#lblMessage").html('');
            var fromDate = $('#NFromDate').val() == null ? "" : $('#NFromDate').val();
            var toDate = $('#NToDate').val() == null ? "" : $('#NToDate').val();
            if (fromDate != '' && toDate != '') {
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("CountDays", "VisitApplication")',
                    data: "{'NFromDate':'" + fromDate + "','NToDate':'" + toDate + "'}",
                    contentType: "application/json; charset=utf-8",
                    dataType: 'json',
                    cache: false,
                    success: function (data) {
                        console.log(data)
                        if (data.Flag==2) {
                            var fDate = $("#frmAddVisitApplication").find("#NFromDate").val();
                            $("#frmAddVisitApplication").find("#NToDate").val(fDate);
                        }
                        else if (data.Flag == 3) {
                            $("#lblMessage").html('');
                            $("#frmAddVisitApplication").find("#NFromDate").val('');
                            $("#frmAddVisitApplication").find("#NToDate").val('');
                            $("#lblMessage").html('चयन गरिएको मिति वर्तमान चलिरहेको आर्थिकमा हुनुपर्छ ।');
                        }
                        $('#lblDaysCount').html(data.Result);
                    },
                    error: function () {
                        //alert("Failed to load Item");
                    }
                });
            }
            }

        });
        $('.inputmask').inputmask({
            mask: '9999-99-99'
        })
    </script>
}





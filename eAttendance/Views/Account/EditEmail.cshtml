@model eAttendance.Models.AspNetUserModel
@{
    //ViewBag.Title = "";
    Layout = "~/Views/Shared/_Blank.cshtml";

}

<div class="modal-dialog">
    <div class="modal-content">
        <div class="modal-header">

            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">×</span><span class="sr-only">Close</span></button>
            <h4 class="modal-title">सम्पादन ईमेल</h4>
            <small class="font-bold"></small>
        </div>


        @using (Html.BeginForm("EditEmail", "Account", FormMethod.Post, new { @id = "EditEmail", @class = "form-horizontal" }))
        {
            @Html.AntiForgeryToken()
            <div class="modal-body">
                @Html.HiddenFor(model => model.Id)
                <div class="form-group">
                    @Html.LabelFor(model => model.Email, new { @class = "control-label col-md-2" })
                    <div class="col-md-8">
                        @Html.TextBoxFor(model => model.Email, new { @class = "form-control" })

                    </div>
                </div>
                <div class="form-group">
                    @Html.LabelFor(model => model.ConfirmEmail, new { @class = "control-label col-md-2" })
                    <div class="col-md-8">
                        @Html.TextBoxFor(model => model.ConfirmEmail, new { @class = "form-control",@id="ConfirmEmailId" })
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary btn-sm">रिसेट गर्नु</button>
                <button type="button" class="btn btn-danger btn-sm" data-dismiss="modal">बन्द गर्नु</button>
            </div>


        }
    </div>
</div>



@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            $("#EditEmail").validate({
                rules: {
                    Email: {
                        required: true,
                        email: true,
                        remote: {
                            url: "@Url.Action("CheckDuplicateEmail", "EmployeeInfo")",
                        type: "POST",
                        data: {
                            Email: function () {return $("#Email").val();}
                                }
                                 }
                            },
                    ConfirmEmail: {
                        required: true,
                        email: true,
                        equalTo: '#Email'
                    }
                },
                messages: {
                    Email: {
                        remote: "Email already exists. Please enter a different Email.",
                        required: 'कृपया आवश्यक जानकारी भर्नुहोस्'
                    },
                    ConfirmEmail: {
                        required: 'कृपया आवश्यक जानकारी भर्नुहोस्',
                        equalTo: 'इमेल मेल खाँदैन'
                    }
                }
            });
        });
    </script>
}

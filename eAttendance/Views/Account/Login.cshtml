@using eAttendance.Models
@model LoginViewModel
@{
    ViewBag.Title = "Attendance Log In";
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";

    eAttendance.Models.ApplicationDbContext db = new eAttendance.Models.ApplicationDbContext();

    var data = db.OfficeSetUp.OrderBy(x => x.DisplayOrder).FirstOrDefault();
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link rel="apple-touch-icon" sizes="76x76" href="../assets/img/apple-icon.png">
    <link rel="icon" type="image/png" href="../assets/img/favicon.png">
    <title>
        @data.OfficeName -हाजिरी व्यवस्थापन प्रणाली
    </title>
    <!--     Fonts and icons     -->
    <link rel="stylesheet" type="text/css" href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700,900|Roboto+Slab:400,700" />
    <!-- Font Awesome Icons -->
    <script src="https://kit.fontawesome.com/42d5adcbca.js" crossorigin="anonymous"></script>
    <!-- Material Icons -->
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
    <!-- CSS Files -->
    <link id="pagestyle" href="~/Content/assets/css/material-dashboard.css?v=3.1.0" rel="stylesheet" />
    <!-- Nepcha Analytics (nepcha.com) -->
    <!-- Nepcha is a easy-to-use web analytics. No cookies and fully compliant with GDPR, CCPA and PECR. -->
    <script defer data-site="YOUR_DOMAIN_HERE" src="https://api.nepcha.com/js/nepcha-analytics.js"></script>

    <link href="~/Content/chosen.css" rel="stylesheet" />

</head>

<body class="bg-gray-200">

    <main class="main-content  mt-0">
        <div class="page-header align-items-start min-vh-100" style="background-image: url('../../Content/assets/attendance.jpeg');">
            <span class="mask bg-gradient-dark opacity-6"></span>
            <div class="container my-auto">
                <div class="row">
                    <div class="col-lg-4 col-md-8 col-12 mx-auto">
                        <div class="card z-index-0 fadeIn3 fadeInBottom">
                            <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
                                <div class="bg-gradient-primary shadow-primary border-radius-lg py-3 pe-1">
                                    <div class="row">
                                        <div class="col-12 text-center ms-auto" style="font-family:Kalimati !important;">
                                            <img src="~/Content/animated-nepal-flag-image-0004.gif" />
                                            @*<img src="~/Images/nepal-logo.png" height="50" width="50" /> <br />*@
                                            @if (data != null)
                                            {
                                                <h4><b>@data.OfficeName</b></h4>
                                                <h5>@data.Address </h5>

                                            }

                                        <p style="font-family:Kalimati !important; font-weight: bold; color:blue;">हाजिरी व्यवस्थापन प्रणाली</p>
                                        </div>
                                    </div>
                                    <h4 class="text-white font-weight-bolder text-center mt-2 mb-0" style="font-family:'Comic Sans MS'">Sign in</h4>
                                </div>
                            </div>
                            <div class="card-body">
                                
                                <form action="@Url.Action("Login", "Account")" role="form" method="post" class="text-start">

                                    @Html.AntiForgeryToken()
                                    @Html.ValidationSummary(false, "", new { @class = "text-danger" })


                                    <div class="input-group input-group-outline my-3">
                                        @Html.TextBoxFor(m => m.UserName, new { @class = "form-control input-lg", placeholder = "User Name", @style = "font-family:'Comic Sans MS'" })
                                        @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "text-danger"})
                                    </div>
                                    <div class="input-group input-group-outline mb-3">
                                        @Html.PasswordFor(m => m.Password, new { @class = "form-control input-lg", placeholder = "Password", @style = "font-family:'Comic Sans MS'" })
                                    </div>

                                    <div class="form-check form-switch d-flex align-items-center mb-3">
                                        @*RememberMe*@
                                        @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input", @id = "rememberMe", @checked = true })
                                        <label class="form-check-label mb-0 ms-3" for="rememberMe" style="font-family:'Comic Sans MS'">Remember me</label>
                                    </div>
                                    <div class="text-center">
                                        <button type="submit" class="btn bg-gradient-primary w-100 my-4 mb-2" style="font-family:'Comic Sans MS'">Sign in</button>
                                    </div>
                                    @*<p class="mt-4 text-sm text-center">
                                            Don't have an account?
                                            <a href="../pages/sign-up.html" class="text-primary text-gradient font-weight-bold">Sign up</a>
                                        </p>*@
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <footer class="footer position-fixed bottom-2 w-100 mt-3 text-center">
                <div class="container">
                    <div class="row align-items-center justify-content-lg-between">
                        <div class="col-md-4 col-4"></div>
                        <div class="col-5 col-md-5 my-auto">
                            <div class="copyright text-left text-sm text-white text-lg-start mt-3" style="font-family:Kalimati;">
                                ©
                                <script>
                                    document.write(new Date().getFullYear())
                                </script>,
                                @data.OfficeName - हाजिरी व्यवस्थापन प्रणाली
                            </div>
                        </div>
                        <div class="col-md-3 col-3"></div>
                    </div>
                </div>
            </footer>
        </div>
    </main>

    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <script src="~/Scripts/chosen.jquery.min.js"></script>

    @section scripts
{
        <script>

            $(document).ready(function () {

                $('.i-checks').iCheck({
                    checkboxClass: 'icheckbox_square-blue',
                    radioClass: 'iradio_square-blue',
                });

                $("#frmLogin").validate({
                    rules: {
                        Email: {
                            required: true,
                            minlength: 3
                        },
                        Password: {
                            required: true,
                            minlength: 6
                        }
                    }
                });
            });
        </script>
    }


</body>

</html>

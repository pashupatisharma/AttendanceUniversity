@model eAttendance.Models.TransferModel

@{
    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_Blank.cshtml";
}

<div class="modal-dialog ">
    <div class="modal-content">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">×</span><span class="sr-only">Close</span></button>
            <h4 class="modal-title">सम्पादन स्थानान्तरण</h4>
            <small class="font-bold"></small>
        </div>

        @using (Html.BeginForm("EditExternalTransfer", "Transfer", FormMethod.Post, new { @id = "frmEditExternalTransfer" }))
        {


            <div class="modal-body">

                <div class="row">
                    <div class="col-sm-12">
                        <div class="form-group">
                            @Html.HiddenFor(m => m.TransferId)
                            @Html.HiddenFor(m => m.TransferType)
                            @Html.HiddenFor(m => m.CreatedBy)
                            @Html.HiddenFor(m => m.CreatedDate)
                            <label class="control-label text-center">@Html.DisplayNameFor(m => m.EmployeeId)</label>
                            @Html.DropDownListFor(m => m.EmployeeId, eAttendance.Utility.GetEmployeeIdWithAll(), new { @class = "chosen-select form-control" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-6">
                        <div class="form-group">
                            <label>@Html.DisplayNameFor(m => m.FromOfficeId)</label>

                            @Html.DropDownListFor(m => m.FromOfficeId, Enumerable.Empty<SelectListItem>(), new { @class = "TxtFrmOfficeId form-control chosen", @id = "frmOfficeId" })
                        </div>

                        <div class="form-group">
                            <label>@Html.DisplayNameFor(m => m.FromBranchId)</label>
                            @Html.DropDownListFor(m => m.FromBranchId, eAttendance.Utility.GetBranchIdName(User), new { @class = "TxtFrmBranchId form-control", @id = "frmBranchId" })
                        </div>
                        <div class="form-group">
                            <label>@Html.DisplayNameFor(m => m.FromServiceId)</label>
                            @Html.DropDownListFor(m => m.FromServiceId, eAttendance.Utility.GetServiceIdName(), new { @class = "TxtFrmServiceId form-control chosen", @id = "frmServiceId" })
                        </div>
                        <div class="form-group">
                            <label>@Html.DisplayNameFor(m => m.FromLevelId)</label>
                            @Html.DropDownListFor(m => m.FromLevelId, eAttendance.Utility.GetLevelIdName(), new { @class = "TxtFrmLevelId form-control chosen", @id = "frmLevelId" })
                        </div>
                        <div class="form-group">
                            <label>@Html.DisplayNameFor(m => m.FromDesignationId)</label>
                            @Html.DropDownListFor(m => m.FromDesignationId, eAttendance.Utility.GetDesignationIdNameList(), new { @class = "TxtFrmDesignationId form-control chosen", @id = "frmDesignationId" })
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="form-group">
                            <label>@Html.DisplayNameFor(m => m.ToOfficeName)</label>
                            @Html.TextBoxFor(m => m.ToOfficeName, new { @class = "chosen-select form-control", @id = "toOfficeId" })
                        </div>

                        @*<div class="form-group">
                                <label>@Html.DisplayNameFor(m => m.ToMainBranchName)</label>
                                @Html.TextBoxFor(m => m.ToMainBranchName, new { @class = "form-control", style = "height:30px" })
                            </div>*@

                        <div class="form-group">
                            <label>@Html.DisplayNameFor(m => m.ToBranchName)</label>
                            @Html.TextBoxFor(m => m.ToBranchName, new { @class = "form-control", @id = "toBranchId" })
                        </div>

                        <div class="form-group">
                            <label>@Html.DisplayNameFor(m => m.ToServiceName)</label>
                            @Html.TextBoxFor(m => m.ToServiceName, new { @class = "form-control", @id = "toServiceId" })
                        </div>

                        <div class="form-group">
                            <label>@Html.DisplayNameFor(m => m.ToLevelName)</label>
                            @Html.TextBoxFor(m => m.ToLevelName, new { @class = "form-control", @id = "toLevelId" })
                        </div>

                        <div class="form-group">
                            <label>@Html.DisplayNameFor(m => m.ToDesignationName)</label>
                            @Html.TextBoxFor(m => m.ToDesignationName, new { @class = "form-control", @id = "toDesignationId" })
                        </div>


                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-12">
                        <div class="form-group">
                            <label class="control-label">@Html.DisplayNameFor(m => m.NTransferDateTime)</label>
                            @Html.TextBoxFor(m => m.NTransferDateTime, "{0:yyyy/MM/dd }", new { @class = "form-control inputmask nepali-calendar", data_mask = "9999-99-99", @id = "NTransferDateTimeExternalEdit" })
                        </div>
                        <div class="form-group">
                            <label>@Html.DisplayNameFor(m => m.Remarks)</label>
                            @Html.TextAreaFor(m => m.Remarks, new { @class = "form-control" })
                        </div>
                    </div>
                </div>
            </div>



            <div class="modal-footer">
                <button type="submit" class="btn btn-primary btn-sm">बचत गर्नु</button>
                <button type="button" class="btn btn-danger btn-sm" data-dismiss="modal">बन्द गर्नु</button>
            </div>
        }
    </div>
</div>


                        min: 1
                    },
                    NTransferDateTime: { required: true, },
                    //FromMainBranchId: {
                    //    min: 1
                    //},
                    //FromBranchId: {
                    //    min: 1
                    //},
                    FromServiceId: {
                        min: 1
                    },
                    FromLevelId: {
                        min: 1
                    },
                    FromDesignationId: {
                        min: 1
                    },
                    ToOfficeName: {
                        required: true,
                    },
                    //ToMainBranchName: {
                    //    required: true,
                    //},
                    //ToBranchName: {
                    //    required: true,
                    //},
                    //ToServiceName: {
                    //    required: true,
                    //},
                    //ToLevelName: {
                    //    required: true,
                    //},
                    //ToDesignationName: {
                    //    required: true,

                    //},

                },
                messages: {

                    EmployeeId: {
                        min: 'कृपया विकल्प चयन गर्नुहोस्'
                    },
                    FromOfficeId: {
                        min: 'कृपया विकल्प चयन गर्नुहोस्'
                    },
                    NTransferDateTime: {
                        required: 'कृपया आवश्यक जानकारी भर्नुहोस्'

                    },
                    @*FromMainBranchId: {
                        min: 'कृपया विकल्प चयन गर्नुहोस्'
                    },
                    FromBranchId: {
                        min: 'कृपया विकल्प चयन गर्नुहोस्'
                    },*@
                    FromServiceId: {
                        min: 'कृपया विकल्प चयन गर्नुहोस्'
                    },
                    FromLevelId: {
                        min: 'कृपया विकल्प चयन गर्नुहोस्'
                    },
                    FromDesignationId: {
                        min: 'कृपया विकल्प चयन गर्नुहोस्'
                    },
                    ToOfficeName: {
                        required: 'कृपया आवश्यक जानकारी भर्नुहोस्'
                    },
                    @*ToMainBranchName: {
                        required: 'कृपया आवश्यक जानकारी भर्नुहोस्'
                        },
                        ToBranchName: {
                        required: 'कृपया आवश्यक जानकारी भर्नुहोस्'
                        },*@
                    @*ToServiceName: {
                            required: 'कृपया आवश्यक जानकारी भर्नुहोस्',

                        },
                        ToLevelName: {
                        required: 'कृपया आवश्यक जानकारी भर्नुहोस्',

                        },
                        ToDesignationName: {
                        required: 'कृपया आवश्यक जानकारी भर्नुहोस्',
                        }*@
                }
            })
        })
    </script>
}

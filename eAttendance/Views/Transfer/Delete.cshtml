@model eAttendance.Models.TransferModel
@{
    Layout = "~/Views/Shared/_Blank.cshtml";
}
<div class="modal-dialog">
    <div class="modal-content">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">×</span><span class="sr-only">Close</span></button>
            <h4 class="modal-title">मेटाउन स्थानान्तरण</h4>
            <small class="font-bold"></small>
        </div>
        @using (Html.BeginForm("Delete", "Transfer", FormMethod.Post, new { @class = "form-horizontal" }))
        {
            <div class="modal-body">
                @Html.HiddenFor(m => m.TransferId)
                @Html.HiddenFor(m=> m.EmployeeId)
                @Html.HiddenFor(m => m.TransferDateTime)
                @Html.HiddenFor(m => m.FromMainBranchId)
                @Html.HiddenFor(m => m.FromBranchId)
                @Html.HiddenFor(m => m.FromServiceId)
                @Html.HiddenFor(m => m.FromLevelId)
                @Html.HiddenFor(m => m.FromDesignationId)
                @Html.HiddenFor(m => m.Remarks)
                @Html.HiddenFor(m => m.FromOfficeId)
                @Html.HiddenFor(m => m.ToOfficeName)
                @Html.HiddenFor(m => m.ToMainBranchName)
                @Html.HiddenFor(m => m.ToBranchName)
                @Html.HiddenFor(m => m.ToServiceName)
                @Html.HiddenFor(m => m.ToLevelName)
                @Html.HiddenFor(m => m.ToDesignationName)
                @Html.HiddenFor(m=> m.CreatedBy)
                @Html.HiddenFor(m=> m.CreatedDate)
                
                <p><i class="fa fa-question-circle"></i>तपाईं मेटाउन निश्चित हुनुहुन्छ?</p>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary btn-sm">हो </button>
                <button type="button" class="btn btn-danger btn-sm" data-dismiss="modal">होइन</button>
            </div>
        }
    </div>
</div>



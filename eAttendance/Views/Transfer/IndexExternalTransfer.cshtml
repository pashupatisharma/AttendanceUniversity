@model PagedList.IPagedList<eAttendance.Models.TransferModel>
@using eAttendance.Models
@using PagedList.Mvc;
@{
    ViewBag.Title = "Transfer Information";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ApplicationDbContext dbContext = new ApplicationDbContext();
}

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-lg-8">
        <h2>कर्मचारी स्थानान्तरण को सूची</h2>
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("Index","Transfer")">घर</a>
            </li>
            <li>
                <a>कर्मचारी</a>
            </li>
            <li class="active">
                <strong>कर्मचारी स्थानान्तरण को सूची</strong>
            </li>
        </ol>
    </div>

    <div class="col-lg-4">
        <div class="title-action">
            <button class="btn-addExternal btn btn-primary"><i class="fa fa-plus-circle"></i>  बाह्य सरुवा </button>
        </div>
    </div>



</div>
<div class="wrapper wrapper-content padding-top-md">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox float-e-margins no-margins">
                <div class="ibox-title">
                    <h5><i class="fa fa-filter"></i> @eAttendance.Service.MenuService.Filter  </h5>
                    <div class="ibox-tools">
                        <a class="collapse-link">
                            <i class="fa fa-chevron-up"></i>
                        </a>
                    </div>
                </div>
                <div class="ibox-content no-border-bottom">
                    @using (Html.BeginForm("IndexExternalTransfer", "Transfer", FormMethod.Get, new { @class = "form-view-data", @id = "EmployeeTransfer" }))
                    {
                        <div class="row">
                            <div class="col-md-9"></div>
                            <div class="col-md-3">
                                <div class="input-group">
                                    @Html.TextBox("searchString", null, new { @class = "form-control" })
                                    <div class="input-group-btn">
                                        <button class="btn btn-primary btn-Search" type="submit">
                                            <i class="fa fa-search"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                    }
                    <div class="project-list">
                        <table id="tblEmployeeTransfer" class="table table-hover">
                            <thead>
                                <tr>
                                    <th>क्र.सं</th>
                                    <th>कर्मचारी</th>
                                    <th>@eAttendance.Service.MenuService.FromOffice</th>
                                    <th>@eAttendance.Service.MenuService.ToOffice</th>
                                    <th>लागु हुने मिति</th>
                         
                                    <th>@eAttendance.Service.MenuService.Remarks</th>
                                </tr>

                            </thead>
                            <tbody>


                       
                                @{int count = 0;}
                                @foreach (var m in ViewBag.OnePageOfBranches)
                                {
                                    count += 1;
                                    <tr>
                                        <td>@count</td>
                                        <td class="project-title">
                                            @Utility.GetEmployeeInfoByEmnployeeId(m.EmployeeId).EmployeeNameNp   [@m.EmployeeNo]
                                        </td>

                                        <td>

                                            @if (m.FromOfficeId != 0)
                                            {
                                                var ofname = Utility.GetOfficeInfoByOfficeId(m.FromOfficeId);
                                                @Html.Raw(ofname.OfficeName)
                                            }


                                            <br />
                                            @Utility.GetBranchByMainBranchId(m.FromBranchId).BranchName

                                            <br />
                                            @Utility.GetServiceByServiceId(m.FromServiceId).ServiceName

                                            <br />
                                            @Utility.GetLevelByLevelId(m.FromLevelId).LevelName

                                            <br />
                                            @Utility.GetDesignationByDesignationId(m.FromDesignationId).DesignationName

                                        </td>
                                        <td>
                                            @if (m.TransferType == 1)
                                            {

                                                var oofname = Utility.GetOfficeInfoByOfficeId(m.ToOfficeId);
                                                @Html.Raw(oofname.OfficeName)
                                                <br />


                                                var branch = Utility.GetBranchByMainBranchId(m.ToBranchId);
                                                @Html.Raw(branch.BranchName)
                                                <br />
                                                var service = Utility.GetServiceByServiceId(m.ToServiceId);
                                                @Html.Raw(service.ServiceName)
                                                <br />
                                                var level = Utility.GetLevelByLevelId(m.ToLevelId);
                                                @Html.Raw(level.LevelName)
                                                <br />
                                                var designation = Utility.GetDesignationByDesignationId(m.ToDesignationId);
                                                @Html.Raw(designation.DesignationName)

                                            }
                                            else if (m.TransferType == 2)
                                            {

                                                @m.ToOfficeName
                                                <br />

                                                @m.ToBranchName
                                                <br />

                                                @m.ToServiceName
                                                <br />

                                                @m.ToLevelName
                                                <br />

                                                @m.ToDesignationName
                                            }

                                        </td>
                                        @if (m.TransferDateTime != null)
                                        {
                                            <td>
                                                @((m.TransferDateTime.Year >= 1913 && m.TransferDateTime.Year <= 2042) ? eAttendance.NepaliDateConverter.ConvertToNepali(m.TransferDateTime.Date) : NepaliDateConverter.ConvertToNepali(DateTime.Today.Date))

                                            </td>
                                        }
                                        else
                                        {
                                            <td>-</td>
                                        }
                                        <td>
                                            @m.Remarks
                                        </td>

                                    </tr>

                                }
                            </tbody>
                        </table>
                        <div class="row">
                            <div class="col-md-3 col-sm-3">
                                <div class="pull-left">
                          
                                    @{ var pager = (PagedList.IPagedList)ViewBag.OnePageOfBranches;}
                                    page @(pager.PageCount < pager.PageNumber ? 0 : pager.PageNumber) of @pager.PageCount
                                </div>
                            </div>
                            <div class=" col-md-9 col-sm-9">
                               @Html.PagedListPager((PagedList.IPagedList)ViewBag.OnePageOfBranches, page => Url.Action("Index", new { page, Email = ViewBag.Email, EmployeeName = ViewBag.EmployeeName, sortOrder = ViewBag.CurrentSort }), PagedListRenderOptions.OnlyShowFivePagesAtATime)


                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
@section Scripts
{
    <div class="modal inmodal fade" id="modelAddInternal" role="dialog">
    </div>
    <div class="modal inmodal fade" id="modelAddExternal" role="dialog">
    </div>
    <div class="modal inmodal fade" id="modelDelete" role="dialog">
    </div>
    <div class="modal inmodal fade" id="modelEdit" role="dialog">
    </div>
    <script type="text/javascript">

        $(document).ready(function () {
            toastr.options = {
                "progressBar": true,
                "positionClass": "toast-top-center",
                "preventDuplicates": false,
                "showDuration": "300",
                "hideDuration": "1000",
                "timeOut": "5000",
                "extendedTimeOut": "1000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut"
            }
            var hasMessage = '@TempData["HasMessage"]';
            if (hasMessage) {
                Command: toastr["@TempData["MessageType"]"]("@TempData["Message"]", "@TempData["MessageHeader"]")
            }

            $('.btn-delete').on('click', function () {
                var transferId = $(this).attr('value');
                $.ajax({
                    url: '@Url.Action("Delete", "Transfer")',
                    type: 'GET',
                    data: { id: transferId },
                    success: function (result) {
                        console.log(result)
                        $("#modelDelete").html(result);
                        $("#modelDelete").modal('show');
                    },
                    error: function () {
                    }
                });
            })

            $('.btn-edit').on('click', function () {
                var transferId = $(this).attr('value');
                $.ajax({
                    url: '@Url.Action("Edit", "Transfer")',
                    type: 'GET',
                    data: { id: transferId },
                    success: function (result) {
                        console.log(result)
                        $("#modelEdit").html(result);
                        $("#modelEdit").modal('show');
                    },
                    error: function () {
                    }
                });
            })



            $('.btn-addExternal').on('click', function () {
                $.ajax({
                    url: '@Url.Action("ExternalTransfer", "Transfer")',
                    type: 'GET',
                    data: {},
                    success: function (result) {
                        console.log(result)
                        $("#modelAddExternal").html(result);
                        $("#modelAddExternal").modal('show');
                    },
                    error: function () {
                    }
                });
            })
        })
    </script>
}
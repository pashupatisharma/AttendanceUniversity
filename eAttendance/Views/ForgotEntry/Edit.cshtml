@model eAttendance.Models.ForgotEntry
@{
    Layout = "~/Views/Shared/_Blank.cshtml";
}
<div class="modal-dialog">
    <div class="modal-content">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">×</span><span class="sr-only">Close</span></button>
            <h4 class="modal-title">हाजिरी छुटेको सम्पादन</h4>
            <small class="font-bold"></small>
        </div>
        @using (Html.BeginForm("Edit", "ForgotEntry", FormMethod.Post, new { @id = "EditForgotEntryForm", @class = "form-horizontal" }))
        {
            @Html.Partial("_Common");
        }
    </div>
</div>
@section scripts
{
    <script src="~/Scripts/plugins/jasny/jasny-bootstrap.min.js"></script>
    <script>
        $(document).ready(function () {
            $(".chosen-select").chosen({ width: '100%' });
            $(".nepali-calendar").nepaliDatePicker();
            $.validator.setDefaults({ ignore: ":hidden:not(select)" });
            $("#EditForgotEntryForm").validate({
                rules: {
                   
                    EmployeeId: {
                        min:1
                    },
                    NForgotDate: {
                        required: true,
                    },
                    NForgotTime: {
                        required: true,
                    },
                    RequestedBy: {
                        min: 1
                    },
                    ApprovedBy: {
                        min: 1
                    },
                },
                messages: {
                    EmployeeId: {
                        min: "Please select an option."
                    },
                    RequestedBy: {
                        min: "Please select an option."
                    },
                    ApprovedBy: {
                        min: "Please select an option."
                    },
                }
            });
        });
        $('.inputmask').inputmask({
            mask: '99:99'
        })
    </script>
}
@model eAttendance.Models.ForgotEntry
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Forget Entry";
}
<div class="wrapper wrapper-content">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <div class="row wrapper white-bg page-heading hidden-print">
                        <div class="col-lg-10">
                            <h2>हाजिरी छुटेको  </h2>
                           
                        </div>
                        <div class="col-lg-2">
                            <h2>&nbsp;</h2>
                            <div class="ibox-tools hidden-print">
                                <button class="btn btn-primary btn-sm btn-add">नयाँ बनाउनु </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="ibox-content">
                    <div class="project-list">
                        <table id="tblForgotEntry" class="table table-hover table-color ">
                            <thead>
                                <tr>
                                    <th>क्र सं</th>
                                    <th>@Html.DisplayNameFor(m => m.EmployeeId)</th>
                                    <th>@Html.DisplayNameFor(m => m.CheckType)</th>
                                    <th>@Html.DisplayNameFor(m => m.ForgotDate)</th>
                                    <th>@Html.DisplayNameFor(m => m.ForgotTime)</th>
                                    <th>@Html.DisplayNameFor(m => m.ApprovedBy)</th>
                                    <th>@Html.DisplayNameFor(m => m.Status)</th>
                                    <th class="hidden-print text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{int count = 0;}
                                @foreach (var m in Model.ForgotEntryList)
                                {
                                    count += 1;
                                    <tr>
                                        <td>@count</td>
                                        <td class="project-title">
                                            <a href="">@eAttendance.Utility.GetEmployeeInfoName().First(w => w.Value == m.EmployeeId.ToString()).Text</a>
                                            <br>
                                        </td>
                                        <td>@Html.Raw((m.CheckType == null || m.CheckType <= 0) ? "-" : eAttendance.Utility.GetCheckType().FirstOrDefault(d => d.Value == m.CheckType.ToString()).Text)</td>
                                        <td>@((m.ForgotDate.Year >= 1913 && m.ForgotDate.Year <= 2042) ? eAttendance.NepaliDateConverter.ConvertToNepali(m.ForgotDate) : NepaliDateConverter.ConvertToNepali(DateTime.Today.Date))</td>
                                        <td>@Html.Raw(m.ForgotTime.ToString(@"hh\:mm"))</td>
                                        <td>@Html.Raw((m.ApprovedBy == null || m.ApprovedBy <= 0) ? "-" : eAttendance.Utility.GetEmployeeInfoName().FirstOrDefault(d => d.Value == m.ApprovedBy.ToString()).Text)</td>
                                        <td>
                                            @switch (m.Status)
                                            {
                                                case 1:
                                                    @Html.Raw("<label class='label label-warning'>" + eAttendance.Service.MenuService.Pending + "</label>")
                                                    break;
                                                case 2:
                                                @Html.Raw("")
                                                    break;
                                                case 3:
                                                @Html.Raw("<label class='label label-info'>" + eAttendance.Service.MenuService.Applyed + "</label>")
                                                    break;
                                                case 4:
                                                @Html.Raw("<label class='label label-success'>" + eAttendance.Service.MenuService.Approved + "</label>")
                                                    break;
                                                case 5:
                                                @Html.Raw("<label class='label label-danger'>" + eAttendance.Service.MenuService.Reject + "</label>")
                                                    break;
                                                default:
                                                    break;
                                            }
                                        </td>
                                        <td class="project-actions hidden-print col-md-2">
                                            @*@if (m.Status != 4 && m.Status != 5)
                                            {
                                                <button value="@m.ForegotEntryId" type="button" class="btn-edit btn btn-primary btn-sm"><i class="fa fa-pencil"></i> <span class="hidden-xs hidden-sm"></span> </button>*@
                                            <button value="@m.ForegotEntryId" class="btn-delete btn btn-sm btn-danger" style="display: block; margin: 0 auto;"><i class="fa fa-remove"></i><span class="hidden-xs hidden-sm"></span> </button>
                                            @*}*@
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal inmodal fade" id="modelAdd" role="dialog">

</div>

<div class="modal inmodal fade" id="modelEdit" role="dialog">

</div>

<div class="modal inmodal fade" id="modelDelete" role="dialog">

</div>

@section Scripts
{

    <script type="text/javascript">
 
            $(".chosen-select").chosen({ width: '100%' });
            $(function () {
                $('#Back').click(function (e) {
                    e.preventDefault();
                    history.go(-1);
                });
         

           
            $('.btn-add').on('click',
                function() {
                    $.ajax({
                        url: '@Url.Action("Add", "ForgotEntry")',
                        type: 'GET',
                        data: {},
                        success: function(result) {
                            console.log(result);
                            $("#modelAdd").html(result);
                            $("#modelAdd").modal('show');
                        },
                        error: function() {
                        }
                    });
                });
            $('#tblForgotEntry tbody').on('click',
                '.btn-edit',
                function() {
                    var ForgotEntryId = $(this).attr('value');
                    $.ajax({
                        url: '@Url.Action("Edit", "ForgotEntry")',
                        type: 'GET',
                        data: { id: ForgotEntryId },
                        success: function(result) {
                            console.log(result);
                            $("#modelEdit").html(result);
                            $("#modelEdit").modal('show');
                        },
                        error: function() {
                        }
                    });

                });
            $('#tblForgotEntry tbody').on('click',
                '.btn-delete',
                function() {
                    var ForgotEntryId = $(this).attr('value');
                    $.ajax({
                        url: '@Url.Action("Delete", "ForgotEntry")',
                        type: 'GET',
                        data: { id: ForgotEntryId },
                        success: function(result) {
                            console.log(result)
                            $("#modelDelete").html(result);
                            $("#modelDelete").modal('show');
                        },
                        error: function() {
                        }
                    });
                });
        })
    </script>
}



@model eAttendance.Models.ForgotEntry
@{
    Layout = "~/Views/Shared/_Blank.cshtml";
}
<div class="modal-dialog">
    <div class="modal-content">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">×</span><span class="sr-only">Close</span></button>
            <h4 class="modal-title">मेटाउन हाजिरी छुटेको</h4>
            <small class="font-bold"></small>
        </div>
        @using (Html.BeginForm("Delete", "ForgotEntry", FormMethod.Post, new { @class = "form-horizontal" }))
        {
            <div class="modal-body">
                @Html.HiddenFor(m => m.ForegotEntryId)
                @Html.HiddenFor(m => m.EmployeeId)
                @Html.HiddenFor(m => m.ShiftTimeId)
                @Html.HiddenFor(m => m.CheckType)
                @Html.HiddenFor(m => m.ForgotDate)
                @Html.HiddenFor(m => m.RequestedBy)
                @Html.HiddenFor(m => m.ApprovedBy)
                @Html.HiddenFor(m => m.Remarks)
                @Html.HiddenFor(m => m.CreatedBy)
                @Html.HiddenFor(m => m.CreatedDate)
                @Html.HiddenFor(m => m.ForgotTime)
                <p><i class="fa fa-question-circle"></i>तपाईं मेटाउन निश्चित हुनुहुन्छ?</p>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary btn-sm">हो </button>
                <button type="button" class="btn btn-danger btn-sm" data-dismiss="modal">होइन</button>
            </div>
        }
    </div>
</div>




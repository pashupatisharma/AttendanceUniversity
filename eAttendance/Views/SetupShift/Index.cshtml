@model eAttendance.Models.Shift
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Setup Shift";
}
<div class="wrapper wrapper-content">
    <div class="modal-content">
        <div class="modal-header">
            <ol class="breadcrumb">
                <li class="animated fadeInUp">सेटअप</li>
                <li class="animated fadeInLeft"><a href="@Url.Action("Index","SetupShift")">शिफ्ट सेटअप</a></li>
                <li class="animated fadeInRight">शिफ्टका सूचीहरु</li>

            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <div class="row wrapper white-bg page-heading hidden-print">
                        <div class="col-lg-10">
                            <h2>शिफ्ट सेटअप</h2>
                        </div>
                        <div class="col-lg-2">
                            <h2>&nbsp;</h2>
                            <div class="ibox-tools hidden-print">
                                <button class="btn btn-primary btn-sm btn-add" onclick="location.href='@Url.Action("Add","SetupShift")'">नयाँ बनाउनु </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="ibox-content">
                    <div class="project-list">
                        <table id="tblSetupShift" class="table table-hover table-condensed  table-color ">
                            <thead>
                                <tr>
                                    <th>क्र सं</th>
                                    <th>@Html.DisplayNameFor(m => m.ShiftName)</th>
                                    <th>@Html.DisplayNameFor(m => m.Status)</th>

                                    <th class="hidden-print text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{int count = 0;}
                                @foreach (var m in Model.ShiftList)
                                {
                                    count += 1;
                                    <tr>
                                        <td>@count</td>
                                        <td>@m.ShiftName</td>
                                        <td>@Html.Raw((m.Status == true) ? "<label class='label label-success lblActive' data-id='1'>True</span>" : "<label class='label label-success lblActive' data-id='1'>False</label>")</td>
                                        <td class="project-actions hidden-print col-md-2">
                                            <button type="button" class="btn-edit btn btn-primary btn-sm" onclick="location.href='@Url.Action("Edit","SetupShift",new { @id=m.ShiftId})'"><i class="fa fa-pencil"></i> <span class="hidden-xs hidden-sm"></span> </button>
                                            <button value="@m.ShiftId" class="btn-delete btn btn-sm btn-danger"><i class="fa fa-remove"></i><span class="hidden-xs hidden-sm"></span> </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="modal inmodal fade" id="modelDelete" role="dialog">
  
</div>

@section Scripts
{


    <script type="text/javascript">
    $(document).ready(function () {
        
 
       
      

        $('#tblSetupShift tbody').on('click', '.btn-delete', function () {
            var ShiftId = $(this).attr('value');
            $.ajax({
                url: '@Url.Action("Delete", "SetupShift")',
                type: 'GET',
                data: { id: ShiftId },
                success: function (result) {
                    console.log(result)
                    $("#modelDelete").html(result);
                    $("#modelDelete").modal('show');
                },
                error: function () {
                }
            });
        })
    })
    </script>

}





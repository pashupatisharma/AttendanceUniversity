                dataType: 'json',
                cache: false,
                success: function (data) {
                    if (data == 1) {

                        var divs = document.getElementsByClassName('chat_area_visit'),
                        i = divs.length;
                        while (i) {
                            i -= 1;
                            if (divs[i].getAttribute('id') == visitApplicationId) {
                                divs[i].parentNode.removeChild(divs[i]);
                            }
                        }
                    }
                },
                error: function () {
                    //alert("Failed to load Item");
                }
            });
        });
        $(".btn-visit-approve-reject-click").click(function () {
            //alert($(this).attr("value"));
            var visitApplicationId = $(this).attr("value");
            $.ajax({
                type: "POST",
                url: '@Url.Action("ApproveVisitApplicationRejectById", "VisitApplication")',
                data: "{'visitApplicationId':'" + visitApplicationId + "'}",
                contentType: "application/json; charset=utf-8",
                dataType: 'json',
                cache: false,
                success: function (data) {
                    if (data == 1) {

                        var divs = document.getElementsByClassName('chat_area_visit'),
                        i = divs.length;
                        while (i) {
                            i -= 1;
                            if (divs[i].getAttribute('id') == visitApplicationId) {
                                divs[i].parentNode.removeChild(divs[i]);
                            }
                        }
                    }
                },
                error: function () {
                    //alert("Failed to load Item");
                }
            });
        });
    })
</script>
}
@model IEnumerable<eAttendance.ViewModel.EmployeeCountDashBoardModl>
@{
    int sno = 1;
}


<div class="table-responsive">
    <table class="table table-striped table-condensed table-mail table-bordered">
        <thead>
            <tr>

                <th class="text-center">क्र.सं.</th>
                <th>कार्यालय को नाम</th>
                <th class="text-center">जम्मा कर्मचारी </th>

                <th class="text-center">उपस्थिती </th>
                <th class="text-center">अनुपस्थित</th>
                <th class="text-center">बिदा</th>
                <th class="text-center">काज</th>
                <th class="text-center">सक्रिय कर्मचारी </th>
                <th class="text-center"> निष्क्रिय कर्मचारी </th>

            </tr>
        </thead>
        <tbody>
            @foreach (var m in Model)
            {
            <tr>
                <td class="text-center">@Html.Raw(EnglishToNepaliNumber.ConvertToNepaliNumber(sno++))</td>
                <td><a href="@Url.Action("Index","Home", new {nlogDate=ViewBag.LogDate, officeId = m.OfficeId})">@m.OfficeName <small></small></a></td>
                <td class="text-center">@EnglishToNepaliNumber.ConvertToNepaliNumber(m.TotalEmployee)</td>

                <td class="text-center">@EnglishToNepaliNumber.ConvertToNepaliNumber(m.Present)</td>
                <td class="text-center">@Html.Raw(EnglishToNepaliNumber.ConvertToNepaliNumber(m.ActiveEmployee - (m.Present + m.OnLeave + m.OnVisit)))</td>
                <td class="text-center">@EnglishToNepaliNumber.ConvertToNepaliNumber(m.OnLeave)</td>
                <td class="text-center">@EnglishToNepaliNumber.ConvertToNepaliNumber(m.OnVisit)</td>
                <td class="text-center">@EnglishToNepaliNumber.ConvertToNepaliNumber(m.ActiveEmployee)</td>
                <td class="text-center">@EnglishToNepaliNumber.ConvertToNepaliNumber(m.InactiveEmployee)</td>

            </tr>
            }
        </tbody>
    </table>
</div>
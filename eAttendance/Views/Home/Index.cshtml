@using eAttendance.Models
@model eAttendance.ViewModel.DashboardViewModel
@{
    int Deactive = Model.TodayAttendanceCount.Total - Model.TodayAttendanceCount.TotalActive;
}
<script type="text/javascript" src="https://www.google.com/jsapi"></script>
<script type="text/javascript">
    google.load("visualization", "1", { packages: ["corechart"] });
</script>





<script type="text/javascript">
    $(function () {
        $.ajax({
            type: 'POST',
            dataType: 'json',
            contentType: 'application/json',
            url: '@Url.Action("GetTodayAttendanceCount", "Home")',
            data: '{}',
            success: function (chartsdata) {

                // Callback that creates and populates a data table,
                // instantiates the pie chart, passes in the data and
                // draws it.

                var data = new google.visualization.DataTable();
                data.addColumn('string', 'Type');
                data.addColumn('number', 'Number');

                for (var i = 0; i < chartsdata.length; i++) {


                    data.addRows([
                        ['उपस्थित', chartsdata[i].Present],
                        ['अनुपस्थित', chartsdata[i].Absent],
                        ['बिदा', chartsdata[i].OnLeave],
                        ['काज', chartsdata[i].OnVisit],



                    ]);
                }





                // Instantiate and draw our chart, passing in some options
                var chart = new google.visualization.PieChart(document.getElementById('chart_div'));


                var chartbar = new google.visualization.BarChart(document.getElementById('chart_divBar'));

                chart.draw(data,
                    {
                        title: "आजको बिवरण",
                        position: "top",
                        fontsize: "5px",
                        chartArea: { width: '100%' },
                        is3D: true

                    });




                chartbar.draw(data,
                    {
                        title: "आजको बिवरण",
                        position: "top",
                        fontsize: "5px",
                        chartArea: { width: '100%' },
                        is3D: true

                    });


            },





            error: function () {
                alert("Error loading data! Please try again.");
            }


        });


    })

</script>










<style>
    hr {
        margin-top: 10px;
        margin-bottom: 8px;
        border: 0;
        border-top: 1px solid #eee;
    }
</style>
<div class="row wrapper white-bg page-heading hidden-print">
    <div class="modal-content">
        <div class="modal-header">
            <ol class="breadcrumb">
                <li><a href="@Url.Action("Index","Home")">Dashboard</a></li>
                <li>AdministratorDashboard</li>

            </ol>
        </div>
    </div>
    <div class="col-lg-12">
        <div class="ibox float-e-margins">
          
            <table id="tblEmployeeInfo" class="table">
                <thead>

                    <tr style="background-color:lightblue">
                        <td colspan="7">
                            <h2> Today Attendance</h2>
                        </td>
                    </tr>
                    <tr style="background-color:lightcyan">


                        <th>

                            Total Employee
                        </th>
                        <th>
                            Active
                        </th>
                        <th>
                            Deactive
                        </th>
                        <th>
                            Present
                        </th>
                        <th>
                            Absent
                        </th>

                        <th>
                            Leave
                        </th>
                        <th>
                            kaaj
                        </th>


                    </tr>
                    <tr style="background-color:lightcyan">
                        <th>     @Model.TodayAttendanceCount.Total</th>
                        <th>@Model.TodayAttendanceCount.TotalActive</th>
                        <th>    @Deactive</th>
                        <th>  @Model.TodayAttendanceCount.Present</th>
                        <th>
                            @Html.Raw(Model.TodayAttendanceCount.TotalActive - (Model.TodayAttendanceCount.Present + Model.TodayAttendanceCount.OnLeave + Model.TodayAttendanceCount.OnVisit))&nbsp;
                        </th>
                        <th>@Model.TodayAttendanceCount.OnLeave</th>
                
                        <th>@Model.TodayAttendanceCount.OnVisit</th>
                    </tr>
                </thead>
            </table>





           
        </div>
    </div>
</div>
<div class="wrapper wrapper-content animated fadeInRight">




    <div class="row">
        <div class="col-lg-12">


            <div class="m-t-sm col-lg-6" id="chart_div" style="width: 530px; height: 530px">

            </div>

            <div class="m-t-sm col-lg-6" id="chart_divBar" style="width: 530px; height: 530px ">

            </div>

        </div>







    </div>
    <div></div><br/>
    <div class="row">
        <div class="col-sm-6">
            <div class="ibox ">
                <div class="ibox-content">
                    <div class="tab-content">
                        <div class="tab-pane active" id="contact-2">
                            <div class="row">
                                <div class="col-lg-12 text-center">
                                    <h2>कर्मचारी बिदा मा</h2>
                                </div>
                            </div>
                            <div id="slimScrollDiv" class="slimScrollDiv">
                                <div class="table-responsive">
                                    <table class="table table-striped table-hover">
                                        <tbody>
                                            @{
                                                if (Model.EmployeeOnLeave != null && Model.EmployeeOnLeave.Count > 0)
                                                {
                                                    ApplicationDbContext dbContext = new ApplicationDbContext();
                                                    foreach (var la in Model.EmployeeOnLeave)
                                                    {
                                                        var levetype = dbContext.LeaveTypeSetUp.Where(x => x.LeaveTypeId == la.LeaveTypeId).FirstOrDefault();
                                                        var employee = dbContext.EmployeeInfo.Where(x => x.EmployeeId == la.EmployeeId).FirstOrDefault();
                                                        <tr>
                                                            <td><a class="client-link" href="" data-toggle="tab">@employee.EmployeeNameNp [@employee.EmployeeNo]</a></td>
                                                            <td>@levetype.LeaveTypeName</td>
                                                        </tr>
                                                    }
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6">
            <div class="ibox ">
                <div class="ibox-content">
                    <div class="tab-content">
                        <div class="tab-pane active" id="contact-2">
                            <div class="row">
                                <div class="col-lg-12 text-center">
                                    <h2>कर्मचारी काज मा</h2>
                                </div>

                            </div>
                            <div id="slimScrollDiv2" class="slimScrollDiv">
                                <div class="table-responsive">
                                    <table class="table table-striped table-hover">
                                        <tbody>
                                            @{
                                                if (Model.EmployeeOnVisit != null && Model.EmployeeOnVisit.Count > 0)
                                                {
                                                    ApplicationDbContext dbContext = new ApplicationDbContext();
                                                    foreach (var va in Model.EmployeeOnVisit)
                                                    {

                                                        var visit = dbContext.VistTypeSetUp.Where(x => x.VisitTypeId == va.VisitTypeId).FirstOrDefault();
                                                        var employee = dbContext.EmployeeInfo.Where(x => x.EmployeeId == va.EmployeeId).FirstOrDefault();

                                                        <tr>
                                                            <td><a class="client-link" href="#" data-toggle="tab">@employee.EmployeeName [@employee.EmployeeNo]</a></td>
                                                            <td>@visit.VisitTypeName</td>
                                                        </tr>
                                                    }
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @if (User.IsInRole("Approver") || User.IsInRole("Recommendatory"))
    {
        <div class="row">
            <div class="col-lg-6">
                <div class="ibox chat-view">
                    <div class="ibox-title">
                        <span class="pull-right text-muted"></span>
                        LeaveApplication
                    </div>
                    @if (Model.LeaveApplicationList != null)
                    {
                        <div class="ibox-content">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="chat-discussion">
                                        @foreach (var leave in Model.LeaveApplicationList.Where(w => w.RecomenderStatus == 1 || w.ApprovedStatus == 1 && w.RecomenderStatus != 3))
                                        {
                                            int? UserId = EmployeeProvider.GetEmployeeIdByUserName(User.Identity.Name);
                                            if (UserId == leave.ApprovedBy || UserId == leave.Recomender)
                                            {
                                        <div class="chat-message chat_area" id="@leave.LeaveApplicationId">
                                            <img class="message-avatar" src="~/Images/user-image.jpg" height="100" width="100">

                        

                                            <div class="message">
                                                <a class="message-author" href="#">
                                                    @Html.Raw((leave.EmployeeId == null || leave.EmployeeId <= 0) ? "-" : Utility.GetEmployeeIdWithAll().FirstOrDefault(d => d.Value == leave.EmployeeId.ToString()).Text)
                                                </a>
                                                <span class="message-date"> @NepaliDateConverter.ConvertToNepali(leave.ApplicationDate.Value.Date) </span>
                                                <span class="message-content">
                                                    मिति : @NepaliDateConverter.ConvertToNepali(leave.FromDate.Value.Date) - @NepaliDateConverter.ConvertToNepali(leave.ToDate.Value.Date)
                                                </span>
                                                <span class="message-content">
                                                    विषय: @leave.Subject
                                                </span>
                                                <br />
                                                <span class="message-content">
                                                    @leave.Message
                                                </span>
                                                <hr />
                                                <div class="message-content">
                                                    @if (User.IsInRole("Recommendatory") && leave.RecomenderStatus == 1 && leave.Recomender == UserId)
                                                    {
                                                        <button id="btnRecomend" value="@leave.LeaveApplicationId" type="button" class="btn btn-success btn-xs btn-click">
                                                            Recomend
                                                        </button>
                                                        <button id="btnRejectRecoment" value="@leave.LeaveApplicationId" type="button" class="btn btn-danger btn-xs btn-rej-click">Reject</button>
                                                    }
                                                    @if (User.IsInRole("Approver") && leave.RecomenderStatus == 2 && leave.ApprovedBy == UserId && leave.ApprovedStatus == 1)
                                                    {
                                                        <button id="btnApprove" value="@leave.LeaveApplicationId" type="button" class="btn btn-success btn-xs btn-leav-approve-click">Approve</button>
                                                        <button id="btnRejectApprove" value="@leave.LeaveApplicationId" type="button" class="btn btn-danger btn-xs btn-leav-reject-click">Reject</button>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                            }
                                        }
                                    </div>
                                </div>

                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-6">
                <div class="ibox chat-view">
                    <div class="ibox-title">
                        <span class="pull-right text-muted"></span>
                        VisitApplication
                    </div>
                    @if (Model.VisitApplicationList != null)
                    {
                        <div class="ibox-content">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="chat-discussion">
                                        @foreach (var visit in Model.VisitApplicationList.Where(w => w.RecomenderStatus == 1 || w.ApprovedStatus == 1 && w.RecomenderStatus != 3))
                                        {
                                      
                                            int? UserId = EmployeeProvider.GetEmployeeIdByUserName(User.Identity.Name);
                                            if (UserId == visit.ApprovedBy || UserId == visit.Recomender)
                                            {
                                        <div class="chat-message chat_area_visit" id="@visit.VisitApplicationId">
                                           
                                            <img class="message-avatar" src="~/Images/user-image.jpg" height="100" width="100">
                                            <div class="message">
                                                <a class="message-author" href="#">
                                                    @Html.Raw((visit.EmployeeId == null || visit.EmployeeId <= 0) ? "-" : Utility.GetEmployeeIdWithAll().FirstOrDefault(d => d.Value == visit.EmployeeId.ToString()).Text)
                                                </a>
                                                <span class="message-date"> @NepaliDateConverter.ConvertToNepali(visit.ApplicationDate.Date) </span>
                                                <span class="message-content">
                                                    मिति : @NepaliDateConverter.ConvertToNepali(visit.FromDate.Date) - @NepaliDateConverter.ConvertToNepali(visit.ToDate.Date)
                                                </span>
                                                <span class="message-content">
                                                    विषय: @visit.Subject
                                                </span>
                                                <br />
                                                <span class="message-content">
                                                    @visit.Message
                                                </span>
                                                <hr />
                                                <div class="message-content">
                                                    @if (User.IsInRole("Recommendatory") && visit.RecomenderStatus == 1 && visit.Recomender == UserId)
                                                    {
                                                        <button id="btnRecomend" value="@visit.VisitApplicationId" type="button" class="btn btn-success btn-xs btn-visit-recomend-click">Recomend</button>
                                                        <button id="btnRejectRecoment" value="@visit.VisitApplicationId" type="button" class="btn btn-danger btn-xs btn-visit-recomend-reject-click">Reject</button>
                                                    }
                                                    @if (User.IsInRole("Approver") && visit.RecomenderStatus == 2 && visit.ApprovedStatus == 1 && visit.ApprovedBy == UserId)
                                                    {
                                                        <button id="btnApprove" type="button" value="@visit.VisitApplicationId" class="btn btn-success btn-xs btn-visit-approve-click">Approve</button>
                                                        <button id="btnRejectApprove" type="button" value="@visit.VisitApplicationId" class="btn btn-danger btn-xs btn-visit-approve-reject-click">Reject</button>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                            }
                                        }
                                    </div>
                                </div>

                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>


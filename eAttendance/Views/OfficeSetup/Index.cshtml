@model eAttendance.Models.OfficeSetUp
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Setup Office";
}

<div class="row wrapper white-bg page-heading hidden-print">

    <div class="modal-content">
        <div class="modal-header">
            <ol class="breadcrumb">
                <li class="animated fadeInUp">सेटअप</li>
                <li class="animated fadeInLeft"><a href="@Url.Action("Index","OfficeSetup")">कार्यलय सेटअप</a></li>
                <li class="animated fadeInRight">कार्यालयका सूचीहरु</li>

            </ol>
        </div>
    </div>

    <div class="col-lg-10">
        <h2>कार्यालय सेटअप</h2>

    </div>
    <div class="col-lg-2">
        <div class="title-action hidden-print">
            <button class="btn btn-primary btn-sm btn-add" onclick="location.href = '@Url.Action("Add","OfficeSetup")'">नयाँ बनाउनु </button>
        </div>
    </div>
</div>
<div class="wrapper wrapper-content padding-top-md">
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header bg-info">
                    <h2 class="m-b-0 text-info">कार्यालय थप </h2>
                </div>
                <div class="card-body">
                    <table id="tblOffice" class="table color-table table-condensed table-color ">
                        <thead>
                            <tr>
                                <th>क्र सं</th>
                                <th>@Html.DisplayNameFor(m => m.OfficeName)</th>
                                <th>@Html.DisplayNameFor(m => m.Code)</th>
                                <th>@Html.DisplayNameFor(m => m.Address)</th>
                                <th>@Html.DisplayNameFor(m => m.DistrictId)</th>
                                <th>@Html.DisplayNameFor(m => m.PhoneNumber)</th>
                                <th class="hidden-print text-center">कार्य </th>
                            </tr>
                        </thead>
                        <tbody>
                            @{int count = 0;}
                            @foreach (var m in Model.SetupOfficeList)
                            {
                                count += 1;
                                <tr>
                                    <td>@count</td>
                                    <td class="project-title">
                                        <a href="">@m.OfficeName</a>
                                    </td>
                                    <td>@m.Code</td>
                                    <td>@m.Address</td>
                                    <td>
                                        @if (m.DistrictSetUp != null)
                                        {
                                            @m.DistrictSetUp.DistrictName
                                        }
                                    </td>

                                    <td>@m.PhoneNumber</td>
                                    <td class="project-actions hidden-print col-md-2">
                                        <button type="button" class="btn-edit btn btn-primary btn-sm" onclick="location.href = '@Url.Action("Edit","OfficeSetup",new {@id=@m.OfficeId })'"><i class="fa fa-pencil"></i> <span class="hidden-xs hidden-sm"></span> </button>
                                        <button value="@m.OfficeId" class="btn-delete btn btn-sm btn-danger"><i class="fa fa-remove"></i><span class="hidden-xs hidden-sm"></span> </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>



@section Scripts
{
    <script type="text/javascript">
        $(document).ready(function () {
              $('.btn-delete').on('click', function () {
              var id = $(this).attr('value');

                $.ajax({
                    url: '@Url.Action("Delete", "OfficeSetUp")',
                    type: 'GET',
                    data: { id: id },
                    success: function (result) {
                        console.log(result)
                        $("#modelDelete").html(result);
                        $("#modelDelete").modal('show');
                    },
                    error: function () {
                    }
                });
            })

        })

    </script>
}

<div class="modal inmodal fade" id="modelDelete" role="dialog">

</div>
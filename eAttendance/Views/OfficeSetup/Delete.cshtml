@model eAttendance.Models.OfficeSetUp
@{
    Layout = "~/Views/Shared/_Blank.cshtml";
}
<div class="modal-dialog">
    <div class="modal-content">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">×</span><span class="sr-only">Close</span></button>
            <h4 class="modal-title">मेटाउन कार्यालय</h4>
            <small class="font-bold"></small>
        </div>
        @using (Html.BeginForm("Delete", "OfficeSetup", FormMethod.Post, new { @class = "form-horizontal" }))
        {
            @Html.AntiForgeryToken()
            <div class="modal-body">
                @Html.HiddenFor(m => m.OfficeId)
                @Html.HiddenFor(m => m.OfficeName)
                @Html.HiddenFor(m => m.Code)
                @Html.HiddenFor(m => m.Address)
                @Html.HiddenFor(m => m.DistrictId)
                @Html.HiddenFor(m => m.PhoneNumber)
                @Html.HiddenFor(m => m.DisplayOrder)
                @Html.HiddenFor(m => m.OfficeHead)
                @Html.HiddenFor(m => m.OfficeSubHead)
                @Html.HiddenFor(m => m.HasMainBranch)
                @Html.HiddenFor(m => m.CreatedBy)
                @Html.HiddenFor(m => m.CreatedDate)
                <p><i class="fa fa-question-circle"></i>तपाईं मेटाउन निश्चित हुनुहुन्छ? </p>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary btn-sm">हो </button>
                <button type="button" class="btn btn-danger btn-sm" data-dismiss="modal">होइन</button>
            </div>
        }
    </div>
</div>




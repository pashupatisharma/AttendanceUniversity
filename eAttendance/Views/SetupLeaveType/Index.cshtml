@model eAttendance.Models.LeaveTypeSetUp
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Setup Leave Type";
}
<div class="row wrapper white-bg page-heading hidden-print">
    <div class="modal-content">
        <div class="modal-header">
            <ol class="breadcrumb">
                <li class="animated fadeInUp">सेटअप</li>
                <li class="animated fadeInLeft"><a href="@Url.Action("Index","SetupLevel")">बिदा प्रकार सेटअप</a></li>
                <li class="animated fadeInRight">बिदा प्रकारका सूचीहरु</li>

            </ol>
        </div>
    </div>

    <div class="col-lg-10">
        <h2> बिदा प्रकार सेटअप </h2>

    </div>
    <div class="col-lg-2">
        <div class="title-action hidden-print">
            <button class="btn btn-primary btn-sm btn-add">नयाँ बनाउनु </button>
        </div>
    </div>
</div>
<div class="wrapper wrapper-content padding-top-md">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5> बिदा प्रकार सेटअप </h5>
                </div>
                <div class="ibox-content">
                    <div class="project-list">
                        <table id="tblLeaveType" class="table table-hover table-color ">
                            <thead>
                                <tr>
                                    <th>क्र सं</th>
                                    <th>@Html.DisplayNameFor(m => m.LeaveTypeName)</th>
                                    <th>@Html.DisplayNameFor(m => m.Alias)</th>
                                    <th>@Html.DisplayNameFor(m => m.Description)</th>
                                    <th>@Html.DisplayNameFor(m => m.DefaultValue)</th>
                                    <th>@Html.DisplayNameFor(m => m.MaximumLimit)</th>
                                    <th class="hidden-print action text-center">कार्य </th>
                                </tr>
                            </thead>
                            <tbody>
                                @{int count = 0;}
                                @foreach (var m in Model.SetupLeaveTypeList)
                                {
                                    count += 1;
                                    <tr>
                                        <td>@count</td>
                                        <td class="project-title">
                                            @m.LeaveTypeName
                                            <span class="pull-right">
                                                @if (m.ApplicableFor == 1)
                                                {
                                                    <span class="btn btn-success btn-circle">
                                                        <i class='fa fa-male'></i>
                                                    </span>
                                                    <span class="btn btn-success btn-circle">
                                                        <i class='fa fa-female'></i>
                                                    </span>
                                                }
                                                else if (m.ApplicableFor == 2)
                                                {
                                                    <span class="btn btn-success btn-circle">
                                                        <i class='fa fa-male'></i>
                                                    </span>
                                                }
                                                else if (m.ApplicableFor == 3)
                                                {
                                                    <span class="btn btn-success btn-circle">
                                                        <i class='fa fa-female'></i>
                                                    </span>
                                                }
                                            </span>
                                        </td>
                                        <td>@m.Alias</td>
                                        <td>@m.Description</td>
                                        <td>@m.DefaultValue</td>
                                        <td>@m.MaximumLimit</td>
                                        <td class="project-actions hidden-print" style="width:90px;">
                                            <button value="@m.LeaveTypeId" type="button" class="btn-edit btn btn-primary btn-sm"><i class="fa fa-pencil"></i> <span class="hidden-xs hidden-sm"></span> </button>
                                            <button value="@m.LeaveTypeId" class="btn-delete btn btn-sm btn-danger"><i class="fa fa-remove"></i><span class="hidden-xs hidden-sm"></span> </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal inmodal fade" id="modelAdd" role="dialog">

</div>
<div class="modal inmodal fade" id="modelEdit" role="dialog">

</div>
<div class="modal inmodal fade" id="modelDelete" role="dialog">

</div>
@section Scripts
{
    <script type="text/javascript">
        $(document).ready(function () {
           

            $('.btn-add').on('click', function () {
                $.ajax({
                    url: '@Url.Action("Add", "SetupLeaveType")',
                    type: 'GET',
                    data: {},
                    success: function (result) {
                        console.log(result)
                        $("#modelAdd").html(result);
                        $("#modelAdd").modal('show');
                    },
                    error: function () {
                      
                    }
                });
            })
            $('#tblLeaveType tbody').on('click', '.btn-edit', function () {
                var leaveTypeId = $(this).attr('value');
                $.ajax({
                    url: '@Url.Action("Edit", "SetupLeaveType")',
                    type: 'GET',
                    data: { id: leaveTypeId },
                    success: function (result) {
                        console.log(result)
                        $("#modelEdit").html(result);
                        $("#modelEdit").modal('show');
                    },
                    error: function () {
                    }
                });
            })
            $('#tblLeaveType tbody').on('click', '.btn-delete', function () {
                var leaveTypeId = $(this).attr('value');
                $.ajax({
                    url: '@Url.Action("Delete", "SetupLeaveType")',
                    type: 'GET',
                    data: { id: leaveTypeId },
                    success: function (result) {
                        console.log(result)
                        $("#modelDelete").html(result);
                        $("#modelDelete").modal('show');
                    },
                    error: function () {
                    }
                });
            })
        })
    </script>
}







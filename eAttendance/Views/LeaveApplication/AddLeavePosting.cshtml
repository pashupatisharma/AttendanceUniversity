@model eAttendance.Models.LeaveApplication
@{
    Layout = "~/Views/Shared/_Blank.cshtml";
}
<div class="modal-dialog modal-lg">
    <div class="modal-content">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">×</span><span class="sr-only">Close</span></button>
            <h4 class="modal-title">बिदा पोस्टिंग</h4>
            <small class="font-bold"></small>
        </div>
        @using (Html.BeginForm("AddLeavePosting", "LeaveApplication", FormMethod.Post, new {enctype = "multipart/form-data", @id = "frmAddLeaveApplication" }))
        {
            @Html.Partial("_CommonLeavePosting")
        }
    </div>
</div>
@section scripts
{
    <script src="~/Scripts/plugins/jasny/jasny-bootstrap.min.js"></script>
    <script>
        $(document).ready(function () {
           
            $('.nepali-calendar').nepaliDatePicker({
                onChange: function () {
                    OnDateChangeEvent();
                }
            });
            $(".chosen-select").chosen({ width: '100%' });
            $.validator.setDefaults({ ignore: ":hidden:not(select)" })
            $('.i-checks').iCheck({
                checkboxClass: 'icheckbox_square-blue',
                radioClass: 'iradio_square-blue'
            });

            DisableAction();
            $("#frmAddLeaveApplication").validate({

                rules: {
                    EmployeeName: {
                        required: true
                    },
                    EmployeeId: {
                        min: 1
                    },
                    LeaveTypeId: {
                        min: 1
                    },
                    Recomender: {
                        min: 1
                    },
                    ApprovedBy: {
                        min: 1
                    },
                    NApprovedDate: {
                        required: true,
                    },
                    NFromDate: {
                        required: true
                    },
                    NToDate: {
                        required: true
                    },
                },
                messages: {
                    EmployeeName: {
                        remote: "Duplicate employee Name found. Please use another name."
                    },
                    EmployeeId: {
                        min: 'कृपया विकल्प चयन गर्नुहोस्'
                    },
                    LeaveTypeId: {
                        min: 'कृपया विकल्प चयन गर्नुहोस्'
                    },
                    Recomender: {
                        min: 'कृपया विकल्प चयन गर्नुहोस्'
                    },
                    ApprovedBy: {
                        min: 'कृपया विकल्प चयन गर्नुहोस्'
                    },
                    NFromDate: {
                        required: 'कृपया विकल्प चयन गर्नुहोस्'
                    },
                    NToDate: {
                        required: 'कृपया विकल्प चयन गर्नुहोस्'
                    },
                    NApprovedDate: {
                        required: 'कृपया विकल्प चयन गर्नुहोस्',
                    }
                }
            });

            $('#EmployeeId').change(function () {
                LoadLeaveType(this.value);
                var leaveTypeId = $("#frmAddLeaveApplication").find("#LeaveTypeId").val();
                LoadLeaveBalance(this.value, leaveTypeId);
                $("#frmAddLeaveApplication").find("#endDate").val('');
                $("#frmAddLeaveApplication").find("#NToDate").val('');
                $("#lblTotalDays").html('0');
                $("#lblTotalHolidays").html('0');
                $("#lblTotalSaturdays").html('0');
                $("#lblAssignedLeave").html('0');
                $("#lblTotalLeaveTaken").html('0');
                $("#lblLeaveBalance").html('0');
            });

            $("#LeaveTypeId").change(function () {
                var employeeId = $("#frmAddLeaveApplication").find("#EmployeeId").val();
                DisableAction();
                LoadLeaveBalance(employeeId, this.value);
                $("#frmAddLeaveApplication").find("#endDate").val('');
                $("#frmAddLeaveApplication").find("#NToDate").val('');
                $("#lblTotalDays").html('0');
                $("#lblTotalHolidays").html('0');
                $("#lblTotalSaturdays").html('0');
            });

            $('#endDate').change(function () {
                OnDateChangeEvent();
            });

            $('#NToDate').change(function () {
                OnDateChangeEvent();
            });
            
            function LoadLeaveType() {
                var employeeId = $("#frmAddLeaveApplication").find("#EmployeeId").val();
                $("#lblErrorMessage").html('');
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("LoadLeaveTypeByEmployeeId", "JsonRequest")',
                    data: "{'employeeId':'" + employeeId + "'}",
                    contentType: "application/json; charset=utf-8",
                    dataType: 'json',
                    cache: false,
                    success: function (data) {
                        //debugger;
                        var a = data.length;
                        if (a<=1) {
                            $("#lblErrorMessage").html('* छनौट भएको कर्मचारीको बिदा सेटअप भएकोछैन् । कृपया छनौट भएको कर्मचारीको बिदा सेटअप मिलाउनुहोस् ।');
                        }
                        var lb = document.getElementById('LeaveTypeId');
                        lb.options.length = 0;
                        lb.innerHTML = '';
                        $.map(data, function (item) {
                            $("#frmAddLeaveApplication").find('#LeaveTypeId').get(0).options[$('#LeaveTypeId').get(0).options.length] = new Option(item.Text, item.Value);
                        });
                       // $("#frmAddLeaveApplication").find('#LeaveTypeId').trigger("chosen:updated");
                    },
                    error: function () {
                        //alert("Failed to load Item");
                    }
                });
            }
            function LoadLeaveBalance(employeeId, leaveTypeId) {
                $("#lblErrorMessage").html('');
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("LoadLeaveBalance", "JsonRequest")',
                    data: "{'employeeId':'" + employeeId + "','leaveTypeId':'" + leaveTypeId + "'}",
                    contentType: "application/json; charset=utf-8",
                    dataType: 'json',
                    cache: false,
                    success: function (data) {
                        //debugger;
                    
                        $("#lblErrorMessage").html('');
                        $("#lblAssignedLeave").html(data.TotalLeave);
                        $("#lblTotalLeaveTaken").html(data.TakenLeave);
                        $("#lblLeaveBalance").html(data.LeaveBalance);
                        if (data.TotalLeave == 0 && leaveTypeId != 0) {
                            $("#lblErrorMessage").html('* छनौट भएको कर्मचारीको बिदा सेटअप भएकोछैन् । कृपया छनौट भएको कर्मचारीको बिदा सेटअप मिलाउनुहोस् ।');
                        }
                        EnableAction();
                    },
                    error: function () {
                        //alert("Failed to load Item");
                    }
                });
            }
            function LoadTotalApplyLeave(fromDate, toDate, leaveTypeId, remainingLeave) {
                if (!leaveTypeId > 0) {
                    return;
                }
                $("#lblErrorMessage").html('');
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("LoadTotalApplyingLeave", "JsonRequest")',
                    data: "{'fromDate':'" + fromDate + "','toDate':'" + toDate + "','leaveTypeId':'" + leaveTypeId + "','remainingLeave':'" + remainingLeave + "'}",
                    contentType: "application/json; charset=utf-8",
                    dataType: 'json',
                    cache: false,
                    success: function (data) {
                        if (data.Flag == 2) {
                            $("#lblErrorMessage").html('');
                            var fDate = $("#frmAddLeaveApplication").find("#endDate").val();
                            $("#frmAddLeaveApplication").find("#NToDate").val(fDate);
                            ReLoadTotalApplyLeave();
                            $("#lblErrorMessage").html('कर्मचारीको बिदाको सीमा अघिक हुनुभएन ।');
                        }
                        if (data.Flag == 3) {
                            $("#lblErrorMessage").html('');
                            var fDate = $("#frmAddLeaveApplication").find("#endDate").val();
                            $("#frmAddLeaveApplication").find("#NToDate").val(fDate);
                            ReLoadTotalApplyLeave();
                        }
                        if (data.Flag == 4) {
                            $("#lblErrorMessage").html('');
                            $("#frmAddLeaveApplication").find("#endDate").val('');
                            $("#frmAddLeaveApplication").find("#NToDate").val('');
                            ReLoadTotalApplyLeave();
                            $("#lblErrorMessage").html('कर्मचारीको बिदाको सीमा अघिक हुनुभएन ।');
                        }
                        if (data.Flag == 5) {
                            $("#lblErrorMessage").html('');
                            $("#frmAddLeaveApplication").find("#endDate").val('');
                            $("#frmAddLeaveApplication").find("#NToDate").val('');
                            ReLoadTotalApplyLeave();
                            $("#lblErrorMessage").html('चयन गरिएको मिति वर्तमान चलिरहेको आर्थिकमा हुनुपर्छ ।');
                        }
                        $("#lblTotalDays").html(data.TotalLeave);
                        $("#lblTotalHolidays").html(data.TotalHolidays);
                        $("#lblTotalSaturdays").html(data.TotalSaturdays);
                        if ($("#frmAddLeaveApplication").find("#endDate").val() != $("#frmAddLeaveApplication").find("#NToDate").val()) {
                            HideIsHalfDay(2);
                        }
                        else { HideIsHalfDay(1); }
                    },
                    error: function () {
                        //alert("Failed to load Item");
                    }
                });
            }
            function ReLoadTotalApplyLeave() {
                var fromDate = $("#frmAddLeaveApplication").find("#endDate").val();
                var toDate = $("#frmAddLeaveApplication").find("#NToDate").val();
                var leaveTypeId = $("#frmAddLeaveApplication").find("#LeaveTypeId").val();
                var remainingLeave = document.getElementById('lblLeaveBalance').innerHTML;
                LoadTotalApplyLeave(fromDate, toDate, leaveTypeId, remainingLeave);
            }

            function DisableAction() {
                $("#frmAddLeaveApplication").find("#endDate").attr("disabled", "disabled");
                $("#frmAddLeaveApplication").find("#NToDate").attr("disabled", "disabled");

            }
            function EnableAction() {
                $("#frmAddLeaveApplication").find("#endDate").attr("disabled", false);
                $("#frmAddLeaveApplication").find("#NToDate").attr("disabled", false);
            }
            function OnDateChangeEvent() {
                var fromDate = $("#frmAddLeaveApplication").find("#endDate").val();
                var toDate = $("#frmAddLeaveApplication").find("#NToDate").val();
                var leaveTypeId = $("#frmAddLeaveApplication").find("#LeaveTypeId").val();
                var remainingLeave = document.getElementById('lblLeaveBalance').innerHTML;
                LoadTotalApplyLeave(fromDate, toDate, leaveTypeId, remainingLeave);
            }
            function HideIsHalfDay(type)
            {
                //type 1:- Unhide
                //type 2:- Hide
                if (type==1) {
                    $("#IsHalfDay").attr("disabled", false);
                    $("#IsHalfDay").prop('value', true);
                }
                else if (type==2) {
                    $("#IsHalfDay").prop('value', false);
                    $(".icheckbox_square-blue").attr("class", "icheckbox_square-blue");
                    $("#IsHalfDay").attr("disabled", true);
                }
            }
        });
        $('.inputmask').inputmask({
            mask: '9999-99-99'
        })
    </script>
}





    <script type="text/javascript">
        function printReport(SheetName) {
            var mywindow = document.getElementById('divprint');
            var popupWin = window.open('', SheetName, 'width=350,height=150,location=no,left=200px');

            popupWin.document.open();

            popupWin.document.write('<link rel="stylesheet" href="../Content/printLandscape.css" type="text/css" />');
            popupWin.document.write('<html><title>' + SheetName + '</title><link rel="stylesheet" type="text/css"  href="../Content/bootstrap.min.css" /></head><body onload="window.print()">')
            popupWin.document.write('<html><title>' + SheetName + '</title><link rel="stylesheet" type="text/css" href="../Content/print.css" /></head><body onload="window.print()">')
            popupWin.document.write(mywindow.innerHTML);

            popupWin.document.write('</html>');

            popupWin.document.close();
        }
    </script>


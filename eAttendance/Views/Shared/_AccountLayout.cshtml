<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>

    <link href="/Content/bootstrap.min.css" rel="stylesheet" />
    <link href="/Content/style.css" rel="stylesheet" />
    <link href="/Content/site.css" rel="stylesheet" />

    <script src="/Scripts/modernizr-2.6.2.js"></script>

</head>
<body id="content">

    <div class="middle-box text-center loginscreen animated fadeInDown">
        <div>
            <div class="logo">
                <img style="width: 90px; width: 90px; margin: 0 auto; text-align: center !important;" src="~/Images/Emblem_of_Nepal.png">
            </div>
            <div> <h3>हाजिरी प्रणाली  </h3></div>


            <div class="widget-head-color-box blue-bg p-lg text-center no-padding border-bottom-blue" style="padding-top:30px !important; margin-top:-40px;">
                <div class="m-b-md">

                </div>
                @RenderBody()
            </div>
        </div>
        <p class="m-t">
            <small>
                @{ var copyright = Utility.GetCompanyInfo();}
                @if (copyright != null)
                {
                    <span class="text-xs block">@copyright.Copyright</span>
                }
            </small>
        </p>
    </div>
    <div class="bg-overlay"></div>
    <!-- Mainly scripts -->
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/app")
    @RenderSection("scripts", required: false)

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Report @ViewBag.Title</title>



    <link href="~/Bootsrap/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Bootsrap/font-awesome/css/font-awesome.min.css" rel="stylesheet" />
    <link href="~/Bootsrap/css/local.css" rel="stylesheet" />


    <script src="~/Bootsrap/js/jquery-1.10.2.min.js"></script>
    <script src="~/Bootsrap/bootstrap/js/bootstrap.min.js"></script>


    <link href="~/Content/themes/base/jquery.ui.timepicker.css" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
